<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        .report-header {
            background: linear-gradient(135deg, #6610f2 0%, #520dc2 100%);
            color: white;
            border-radius: 15px;
            padding: 25px;
            margin-bottom: 25px;
        }
        .stat-card {
            border-radius: 12px;
            border: none;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
            transition: transform 0.3s ease;
            height: 100%;
        }
        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
        }
        .stat-icon {
            width: 50px;
            height: 50px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            color: white;
        }
        .chart-container {
            background: white;
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 25px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }
        .report-tabs {
            background: white;
            border-radius: 12px;
            padding: 15px;
            margin-bottom: 25px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }
        .report-tab {
            padding: 10px 20px;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
            color: #6c757d;
        }
        .report-tab:hover {
            background: #f8f9fa;
            color: #6610f2;
        }
        .report-tab.active {
            background: #6610f2;
            color: white;
        }
        .filter-section {
            background: #f8f9fa;
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 20px;
        }
        .kpi-card {
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            border-left: 4px solid #6610f2;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 15px;
        }
        .data-table {
            font-size: 0.9rem;
        }
        .data-table th {
            background: #f8f9fa;
            position: sticky;
            top: 0;
        }
        .table-responsive {
            max-height: 500px;
            overflow-y: auto;
        }
        .badge-trend-up {
            background: #d4edda;
            color: #155724;
            padding: 3px 8px;
            border-radius: 20px;
            font-size: 0.75rem;
        }
        .badge-trend-down {
            background: #f8d7da;
            color: #721c24;
            padding: 3px 8px;
            border-radius: 20px;
            font-size: 0.75rem;
        }
        .loading-spinner {
            display: none;
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            z-index: 9999;
        }
        .loading-spinner.active {
            display: block;
        }
        .export-btn {
            background: white;
            border: 2px solid #28a745;
            color: #28a745;
            padding: 8px 20px;
            border-radius: 8px;
            transition: all 0.3s ease;
        }
        .export-btn:hover {
            background: #28a745;
            color: white;
        }
        .date-range-badge {
            background: #e9ecef;
            padding: 5px 10px;
            border-radius: 20px;
            font-size: 0.85rem;
        }
    </style>
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/dashboard">
                <i class="bi bi-cash-coin me-2"></i> Millenium Cash
            </a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/dashboard">Dashboard</a>
                <a class="nav-link" href="/admin/users">User Management</a>
                <a class="nav-link" href="/admin/register">Register Staff</a>
                <a class="nav-link" href="/loans">Loan Management</a>
                <a class="nav-link active" href="/admin/reports">Reports</a>
                <a class="nav-link" href="/profile">Profile</a>
                <a class="nav-link" href="/logout">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container my-4">
        <!-- Report Header -->
        <div class="report-header">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h1 class="mb-2"><i class="bi bi-graph-up me-2"></i>System Reports & Analytics</h1>
                    <p class="mb-0 opacity-75">Comprehensive insights into your loan portfolio and operations</p>
                </div>
                <div class="col-md-4 text-end">
                    <span class="date-range-badge bg-white text-dark">
                        <i class="bi bi-calendar3 me-1"></i>
                        <%= startDate %> to <%= endDate %>
                    </span>
                </div>
            </div>
        </div>

        <!-- Loading Spinner -->
        <div class="loading-spinner" id="loadingSpinner">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>

        <!-- Date Range Filter -->
        <div class="filter-section">
            <form id="dateRangeForm" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label fw-bold">Date Range</label>
                    <select class="form-select" id="dateRange" name="range">
                        <option value="today" <%= dateRange === 'today' ? 'selected' : '' %>>Today</option>
                        <option value="week" <%= dateRange === 'week' ? 'selected' : '' %>>Last 7 Days</option>
                        <option value="month" <%= dateRange === 'month' ? 'selected' : '' %>>Last 30 Days</option>
                        <option value="quarter" <%= dateRange === 'quarter' ? 'selected' : '' %>>Last 90 Days</option>
                        <option value="year" <%= dateRange === 'year' ? 'selected' : '' %>>Last 12 Months</option>
                        <option value="custom" <%= dateRange === 'custom' ? 'selected' : '' %>>Custom Range</option>
                    </select>
                </div>
                <div class="col-md-3" id="customStartDate" style="display: <%= dateRange === 'custom' ? 'block' : 'none' %>;">
                    <label class="form-label">Start Date</label>
                    <input type="date" class="form-control" id="startDate" value="<%= startDate %>">
                </div>
                <div class="col-md-3" id="customEndDate" style="display: <%= dateRange === 'custom' ? 'block' : 'none' %>;">
                    <label class="form-label">End Date</label>
                    <input type="date" class="form-control" id="endDate" value="<%= endDate %>">
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-funnel me-2"></i>Apply Filters
                    </button>
                </div>
                <div class="col-md-3">
                    <button type="button" class="btn btn-export w-100" id="exportBtn" onclick="exportReport()">
                        <i class="bi bi-download me-2"></i>Export Report
                    </button>
                </div>
            </form>
        </div>

        <!-- Report Tabs -->
        <div class="report-tabs">
            <div class="d-flex flex-wrap gap-2">
                <div class="report-tab <%= reportType === 'overview' ? 'active' : '' %>" onclick="changeReportType('overview')">
                    <i class="bi bi-grid me-2"></i>Overview
                </div>
                <div class="report-tab <%= reportType === 'loans' ? 'active' : '' %>" onclick="changeReportType('loans')">
                    <i class="bi bi-clipboard-data me-2"></i>Loan Performance
                </div>
                <div class="report-tab <%= reportType === 'payments' ? 'active' : '' %>" onclick="changeReportType('payments')">
                    <i class="bi bi-cash-stack me-2"></i>Payments & Collections
                </div>
                <div class="report-tab <%= reportType === 'customers' ? 'active' : '' %>" onclick="changeReportType('customers')">
                    <i class="bi bi-people me-2"></i>Customer Analytics
                </div>
            </div>
        </div>

        <!-- Report Content -->
        <div id="reportContent">
            <!-- Dynamic content loaded via JavaScript -->
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let charts = {};

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', function() {
            loadReportData();
            
            // Date range toggle
            document.getElementById('dateRange').addEventListener('change', function() {
                const isCustom = this.value === 'custom';
                document.getElementById('customStartDate').style.display = isCustom ? 'block' : 'none';
                document.getElementById('customEndDate').style.display = isCustom ? 'block' : 'none';
            });
            
            // Form submit
            document.getElementById('dateRangeForm').addEventListener('submit', function(e) {
                e.preventDefault();
                loadReportData();
            });
        });

        // Change report type
        function changeReportType(type) {
            // Update URL without reload
            const url = new URL(window.location);
            url.searchParams.set('type', type);
            window.history.pushState({}, '', url);
            
            // Update active tab
            document.querySelectorAll('.report-tab').forEach(tab => {
                tab.classList.remove('active');
            });
            event.target.closest('.report-tab').classList.add('active');
            
            // Load new data
            loadReportData();
        }

        // Load report data based on type
        async function loadReportData() {
            showLoading();
            
            const type = new URLSearchParams(window.location.search).get('type') || 'overview';
            const range = document.getElementById('dateRange').value;
            let startDate, endDate;
            
            if (range === 'custom') {
                startDate = document.getElementById('startDate').value;
                endDate = document.getElementById('endDate').value;
            } else {
                // Calculate dates based on range
                const today = new Date();
                endDate = today.toISOString().split('T')[0];
                
                switch(range) {
                    case 'today':
                        startDate = endDate;
                        break;
                    case 'week':
                        startDate = new Date(today.setDate(today.getDate() - 7)).toISOString().split('T')[0];
                        break;
                    case 'month':
                        startDate = new Date(today.setMonth(today.getMonth() - 1)).toISOString().split('T')[0];
                        break;
                    case 'quarter':
                        startDate = new Date(today.setMonth(today.getMonth() - 3)).toISOString().split('T')[0];
                        break;
                    case 'year':
                        startDate = new Date(today.setFullYear(today.getFullYear() - 1)).toISOString().split('T')[0];
                        break;
                }
            }
            
            try {
                let response;
                switch(type) {
                    case 'overview':
                        response = await fetch(`/api/reports/overview?startDate=${startDate}&endDate=${endDate}`);
                        break;
                    case 'loans':
                        response = await fetch(`/api/reports/loans?startDate=${startDate}&endDate=${endDate}`);
                        break;
                    case 'payments':
                        response = await fetch(`/api/reports/payments?startDate=${startDate}&endDate=${endDate}`);
                        break;
                    case 'customers':
                        response = await fetch(`/api/reports/customers?startDate=${startDate}&endDate=${endDate}`);
                        break;
                }
                
                const result = await response.json();
                
                if (result.success) {
                    renderReport(type, result.data);
                } else {
                    showError('Error loading report data');
                }
            } catch (error) {
                console.error('Error:', error);
                showError('Failed to load report data');
            }
            
            hideLoading();
        }

        // Render report based on type
        function renderReport(type, data) {
            const content = document.getElementById('reportContent');
            
            switch(type) {
                case 'overview':
                    renderOverviewReport(content, data);
                    break;
                case 'loans':
                    renderLoanReport(content, data);
                    break;
                case 'payments':
                    renderPaymentReport(content, data);
                    break;
                case 'customers':
                    renderCustomerReport(content, data);
                    break;
            }
        }

        // Render Overview Report
        function renderOverviewReport(container, data) {
            const loanStats = data.loanStats[0] || {};
            const customerStats = data.customerStats[0] || {};
            const paymentStats = data.paymentStats[0] || {};
            const userActivity = data.userActivity[0] || {};
            
            let html = `
                <!-- KPI Cards -->
                <div class="row mb-4">
                    <div class="col-md-3 mb-3">
                        <div class="stat-card">
                            <div class="card-body">
                                <div class="d-flex justify-content-between">
                                    <div>
                                        <h6 class="text-muted mb-2">Total Loans</h6>
                                        <h2 class="mb-0">${loanStats.total_loans || 0}</h2>
                                        <small class="text-success">
                                            <i class="bi bi-arrow-up"></i>
                                            ${loanStats.approved_loans || 0} approved
                                        </small>
                                    </div>
                                    <div class="stat-icon bg-primary">
                                        <i class="bi bi-clipboard-data"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 mb-3">
                        <div class="stat-card">
                            <div class="card-body">
                                <div class="d-flex justify-content-between">
                                    <div>
                                        <h6 class="text-muted mb-2">Loan Amount</h6>
                                        <h2 class="mb-0">₱${(loanStats.total_loan_amount || 0).toLocaleString()}</h2>
                                        <small class="text-info">
                                            <i class="bi bi-cash"></i>
                                            Avg: ₱${(loanStats.avg_loan_amount || 0).toLocaleString()}
                                        </small>
                                    </div>
                                    <div class="stat-icon bg-success">
                                        <i class="bi bi-cash-stack"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 mb-3">
                        <div class="stat-card">
                            <div class="card-body">
                                <div class="d-flex justify-content-between">
                                    <div>
                                        <h6 class="text-muted mb-2">Collections</h6>
                                        <h2 class="mb-0">₱${(paymentStats.total_collected || 0).toLocaleString()}</h2>
                                        <small class="text-warning">
                                            <i class="bi bi-credit-card"></i>
                                            ${paymentStats.total_payments || 0} payments
                                        </small>
                                    </div>
                                    <div class="stat-icon bg-warning">
                                        <i class="bi bi-cash"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 mb-3">
                        <div class="stat-card">
                            <div class="card-body">
                                <div class="d-flex justify-content-between">
                                    <div>
                                        <h6 class="text-muted mb-2">Customers</h6>
                                        <h2 class="mb-0">${customerStats.total_customers || 0}</h2>
                                        <small class="text-secondary">
                                            <i class="bi bi-person-check"></i>
                                            ${customerStats.verified_customers || 0} verified
                                        </small>
                                    </div>
                                    <div class="stat-icon bg-info">
                                        <i class="bi bi-people"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Charts Row -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <div class="chart-container">
                            <h6 class="mb-3"><i class="bi bi-bar-chart me-2"></i>Loan Status Distribution</h6>
                            <canvas id="statusChart"></canvas>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="chart-container">
                            <h6 class="mb-3"><i class="bi bi-pie-chart me-2"></i>Purpose Categories</h6>
                            <canvas id="purposeChart"></canvas>
                        </div>
                    </div>
                </div>

                <!-- Daily Trends -->
                <div class="row mb-4">
                    <div class="col-12">
                        <div class="chart-container">
                            <h6 class="mb-3"><i class="bi bi-graph-up me-2"></i>Daily Loan Trends</h6>
                            <canvas id="trendChart"></canvas>
                        </div>
                    </div>
                </div>

                <!-- Employee Performance -->
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header bg-white">
                                <h6 class="mb-0"><i class="bi bi-trophy me-2 text-warning"></i>Top Performing Employees</h6>
                            </div>
                            <div class="card-body">
                                <div class="table-responsive">
                                    <table class="table table-hover data-table">
                                        <thead>
                                            <tr>
                                                <th>Employee</th>
                                                <th>Loans Processed</th>
                                                <th>Approved</th>
                                                <th>Total Amount</th>
                                                <th>Avg Amount</th>
                                                <th>Performance</th>
                                            </tr>
                                        </thead>
                                        <tbody>
            `;
            
            if (data.employeePerformance && data.employeePerformance.length > 0) {
                data.employeePerformance.forEach(emp => {
                    const approvalRate = emp.loans_processed > 0 
                        ? ((emp.approved_loans / emp.loans_processed) * 100).toFixed(1) 
                        : 0;
                    
                    html += `
                        <tr>
                            <td>
                                <strong>${emp.full_name}</strong><br>
                                <small class="text-muted">${emp.email}</small>
                            </td>
                            <td>${emp.loans_processed || 0}</td>
                            <td>${emp.approved_loans || 0}</td>
                            <td>₱${(emp.total_amount || 0).toLocaleString()}</td>
                            <td>₱${(emp.avg_amount || 0).toLocaleString()}</td>
                            <td>
                                <div class="progress" style="height: 5px;">
                                    <div class="progress-bar bg-success" style="width: ${approvalRate}%"></div>
                                </div>
                                <small>${approvalRate}% approval</small>
                            </td>
                        </tr>
                    `;
                });
            } else {
                html += '<tr><td colspan="6" class="text-center">No employee data available</td></tr>';
            }
            
            html += `
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            `;
            
            container.innerHTML = html;
            
            // Initialize charts after content is loaded
            setTimeout(() => {
                loadChartData();
            }, 100);
        }

        // Render Loan Report
        function renderLoanReport(container, data) {
            const summary = data.summary || {};
            const loans = data.loans || [];
            
            let html = `
                <!-- Loan Summary Cards -->
                <div class="row mb-4">
                    <div class="col-md-3 mb-3">
                        <div class="kpi-card">
                            <h6 class="text-muted">Total Loans</h6>
                            <h3>${summary.total_loans || 0}</h3>
                            <small class="text-success">
                                <i class="bi bi-arrow-up"></i> 
                                ₱${(summary.total_amount || 0).toLocaleString()}
                            </small>
                        </div>
                    </div>
                    <div class="col-md-3 mb-3">
                        <div class="kpi-card">
                            <h6 class="text-muted">Average Amount</h6>
                            <h3>₱${(summary.avg_amount || 0).toLocaleString()}</h3>
                            <small class="text-info">Per loan</small>
                        </div>
                    </div>
                    <div class="col-md-3 mb-3">
                        <div class="kpi-card">
                            <h6 class="text-muted">Approved</h6>
                            <h3>${summary.by_status?.approved?.count || 0}</h3>
                            <small class="text-success">
                                ₱${((summary.by_status?.approved?.amount || 0)).toLocaleString()}
                            </small>
                        </div>
                    </div>
                    <div class="col-md-3 mb-3">
                        <div class="kpi-card">
                            <h6 class="text-muted">Pending</h6>
                            <h3>${summary.by_status?.pending?.count || 0}</h3>
                            <small class="text-warning">
                                ₱${((summary.by_status?.pending?.amount || 0)).toLocaleString()}
                            </small>
                        </div>
                    </div>
                </div>

                <!-- Loans Table -->
                <div class="card">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <h6 class="mb-0"><i class="bi bi-table me-2"></i>Loan Applications</h6>
                        <div>
                            <select class="form-select form-select-sm" id="statusFilter" onchange="filterLoans()">
                                <option value="all">All Status</option>
                                <option value="pending">Pending</option>
                                <option value="approved">Approved</option>
                                <option value="rejected">Rejected</option>
                                <option value="disbursed">Disbursed</option>
                            </select>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover data-table">
                                <thead>
                                    <tr>
                                        <th>Loan ID</th>
                                        <th>Customer</th>
                                        <th>Pension No.</th>
                                        <th>Amount</th>
                                        <th>Term</th>
                                        <th>Rate</th>
                                        <th>Status</th>
                                        <th>Applied Date</th>
                                        <th>Processed By</th>
                                        <th>Days</th>
                                    </tr>
                                </thead>
                                <tbody>
            `;
            
            if (loans.length > 0) {
                loans.forEach(loan => {
                    const daysPending = loan.days_pending || 0;
                    const daysClass = daysPending > 7 ? 'text-danger' : (daysPending > 3 ? 'text-warning' : 'text-success');
                    
                    html += `
                        <tr>
                            <td><strong>#${loan.loan_id}</strong></td>
                            <td>${loan.first_name} ${loan.last_name}</td>
                            <td>${loan.pension_number || 'N/A'}</td>
                            <td>₱${parseFloat(loan.loan_amount).toLocaleString()}</td>
                            <td>${loan.duration_months} mo</td>
                            <td>${loan.interest_rate}%</td>
                            <td>
                                <span class="badge bg-${loan.status === 'pending' ? 'warning' : 
                                                          loan.status === 'approved' ? 'success' : 
                                                          loan.status === 'rejected' ? 'danger' : 
                                                          loan.status === 'disbursed' ? 'info' : 'secondary'}">
                                    ${loan.status}
                                </span>
                            </td>
                            <td>${new Date(loan.applied_date).toLocaleDateString()}</td>
                            <td>${loan.processed_by_name || 'N/A'}</td>
                            <td class="${daysClass}">${daysPending} days</td>
                        </tr>
                    `;
                });
            } else {
                html += '<tr><td colspan="10" class="text-center">No loan data available</td></tr>';
            }
            
            html += `
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            `;
            
            container.innerHTML = html;
        }

        // Render Payment Report
        function renderPaymentReport(container, data) {
            const summary = data.summary || {};
            const payments = data.payments || [];
            
            let html = `
                <!-- Payment Summary Cards -->
                <div class="row mb-4">
                    <div class="col-md-4 mb-3">
                        <div class="kpi-card">
                            <h6 class="text-muted">Total Collections</h6>
                            <h3>₱${(summary.total_collected || 0).toLocaleString()}</h3>
                            <small class="text-success">
                                <i class="bi bi-cash"></i> 
                                ${summary.total_payments || 0} payments
                            </small>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <div class="kpi-card">
                            <h6 class="text-muted">Average Payment</h6>
                            <h3>₱${(summary.avg_payment || 0).toLocaleString()}</h3>
                            <small class="text-info">Per transaction</small>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <div class="kpi-card">
                            <h6 class="text-muted">Collection Rate</h6>
                            <h3>${summary.by_status?.paid?.count || 0}/${summary.total_payments || 0}</h3>
                            <small class="text-success">
                                ${((summary.by_status?.paid?.count || 0) / (summary.total_payments || 1) * 100).toFixed(1)}% on-time
                            </small>
                        </div>
                    </div>
                </div>

                <!-- Payment Method Distribution -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <div class="chart-container">
                            <h6 class="mb-3"><i class="bi bi-pie-chart me-2"></i>Payment Methods</h6>
                            <canvas id="paymentMethodChart"></canvas>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="chart-container">
                            <h6 class="mb-3"><i class="bi bi-bar-chart me-2"></i>Payment Status</h6>
                            <canvas id="paymentStatusChart"></canvas>
                        </div>
                    </div>
                </div>

                <!-- Payments Table -->
                <div class="card">
                    <div class="card-header bg-white">
                        <h6 class="mb-0"><i class="bi bi-table me-2"></i>Payment Transactions</h6>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover data-table">
                                <thead>
                                    <tr>
                                        <th>Receipt #</th>
                                        <th>Customer</th>
                                        <th>Loan ID</th>
                                        <th>Amount Paid</th>
                                        <th>Amount Due</th>
                                        <th>Payment Date</th>
                                        <th>Method</th>
                                        <th>Status</th>
                                        <th>Posted By</th>
                                    </tr>
                                </thead>
                                <tbody>
            `;
            
            if (payments.length > 0) {
                payments.forEach(payment => {
                    html += `
                        <tr>
                            <td><strong>${payment.receipt_number || 'N/A'}</strong></td>
                            <td>${payment.first_name || ''} ${payment.last_name || ''}</td>
                            <td>#${payment.loan_id}</td>
                            <td>₱${parseFloat(payment.amount_paid || 0).toLocaleString()}</td>
                            <td>₱${parseFloat(payment.amount_due || 0).toLocaleString()}</td>
                            <td>${new Date(payment.payment_date).toLocaleDateString()}</td>
                            <td>
                                <span class="badge bg-secondary">${payment.payment_method || 'cash'}</span>
                            </td>
                            <td>
                                <span class="badge bg-${payment.payment_status === 'paid' ? 'success' : 
                                                          payment.payment_status === 'partial' ? 'warning' : 
                                                          payment.payment_status === 'overdue' ? 'danger' : 'secondary'}">
                                    ${payment.payment_status}
                                </span>
                            </td>
                            <td>${payment.posted_by_name || 'N/A'}</td>
                        </tr>
                    `;
                });
            } else {
                html += '<tr><td colspan="9" class="text-center">No payment data available</td></tr>';
            }
            
            html += `
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            `;
            
            container.innerHTML = html;
            
            // Initialize payment charts
            setTimeout(() => {
                renderPaymentCharts(summary);
            }, 100);
        }

        // Render Customer Report
        function renderCustomerReport(container, data) {
            const summary = data.summary || {};
            const customers = data.customers || [];
            
            let html = `
                <!-- Customer Summary Cards -->
                <div class="row mb-4">
                    <div class="col-md-4 mb-3">
                        <div class="kpi-card">
                            <h6 class="text-muted">Total Customers</h6>
                            <h3>${summary.total_customers || 0}</h3>
                            <small class="text-success">
                                <i class="bi bi-person-check"></i> 
                                ${summary.verified || 0} verified
                            </small>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <div class="kpi-card">
                            <h6 class="text-muted">Pension Systems</h6>
                            <h3>${Object.keys(summary.by_system || {}).length}</h3>
                            <small class="text-info">Active pension systems</small>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <div class="kpi-card">
                            <h6 class="text-muted">Locations</h6>
                            <h3>${Object.keys(summary.by_city || {}).length}</h3>
                            <small class="text-warning">Cities covered</small>
                        </div>
                    </div>
                </div>

                <!-- Pension System Distribution -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <div class="chart-container">
                            <h6 class="mb-3"><i class="bi bi-pie-chart me-2"></i>Pension System Distribution</h6>
                            <canvas id="pensionSystemChart"></canvas>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="chart-container">
                            <h6 class="mb-3"><i class="bi bi-bar-chart me-2"></i>Geographic Distribution</h6>
                            <canvas id="geoChart"></canvas>
                        </div>
                    </div>
                </div>

                <!-- Customers Table -->
                <div class="card">
                    <div class="card-header bg-white">
                        <h6 class="mb-0"><i class="bi bi-table me-2"></i>Customer List</h6>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover data-table">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Customer Name</th>
                                        <th>Pension No.</th>
                                        <th>Pension System</th>
                                        <th>Monthly Pension</th>
                                        <th>Mobile</th>
                                        <th>City</th>
                                        <th>Status</th>
                                        <th>Total Loans</th>
                                        <th>Total Borrowed</th>
                                    </tr>
                                </thead>
                                <tbody>
            `;
            
            if (customers.length > 0) {
                customers.forEach(customer => {
                    html += `
                        <tr>
                            <td>#${customer.customer_id}</td>
                            <td><strong>${customer.first_name} ${customer.last_name}</strong></td>
                            <td>${customer.pension_number || 'N/A'}</td>
                            <td>${customer.pension_system || 'N/A'}</td>
                            <td>₱${parseFloat(customer.monthly_pension || 0).toLocaleString()}</td>
                            <td>${customer.mobile_number || 'N/A'}</td>
                            <td>${customer.city || 'N/A'}</td>
                            <td>
                                <span class="badge bg-${customer.verification_status === 'verified' ? 'success' : 'warning'}">
                                    ${customer.verification_status}
                                </span>
                            </td>
                            <td>${customer.total_loans || 0}</td>
                            <td>₱${parseFloat(customer.total_borrowed || 0).toLocaleString()}</td>
                        </tr>
                    `;
                });
            } else {
                html += '<tr><td colspan="10" class="text-center">No customer data available</td></tr>';
            }
            
            html += `
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            `;
            
            container.innerHTML = html;
            
            // Initialize customer charts
            setTimeout(() => {
                renderCustomerCharts(summary);
            }, 100);
        }

        // Load chart data
        async function loadChartData() {
            try {
                const response = await fetch('/api/reports/chart-data');
                const result = await response.json();
                
                if (result.success) {
                    renderCharts(result.data);
                }
            } catch (error) {
                console.error('Error loading chart data:', error);
            }
        }

        // Render main charts
        function renderCharts(data) {
            // Destroy existing charts
            Object.values(charts).forEach(chart => {
                if (chart) chart.destroy();
            });
            
            // Status Distribution Chart
            const statusCtx = document.getElementById('statusChart')?.getContext('2d');
            if (statusCtx && data.statusDistribution) {
                charts.statusChart = new Chart(statusCtx, {
                    type: 'doughnut',
                    data: {
                        labels: data.statusDistribution.map(d => d.label),
                        datasets: [{
                            data: data.statusDistribution.map(d => d.value),
                            backgroundColor: ['#ffc107', '#28a745', '#dc3545', '#17a2b8', '#6c757d']
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: { position: 'bottom' }
                        }
                    }
                });
            }
            
            // Purpose Distribution Chart
            const purposeCtx = document.getElementById('purposeChart')?.getContext('2d');
            if (purposeCtx && data.purposeDistribution) {
                charts.purposeChart = new Chart(purposeCtx, {
                    type: 'bar',
                    data: {
                        labels: data.purposeDistribution.map(d => d.purpose_category || 'Other'),
                        datasets: [{
                            label: 'Number of Loans',
                            data: data.purposeDistribution.map(d => d.count),
                            backgroundColor: '#6610f2'
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: { display: false }
                        }
                    }
                });
            }
            
            // Trend Chart
            const trendCtx = document.getElementById('trendChart')?.getContext('2d');
            if (trendCtx && data.loanTrends && data.amountTrends) {
                charts.trendChart = new Chart(trendCtx, {
                    type: 'line',
                    data: {
                        labels: data.loanTrends.map(d => d.label),
                        datasets: [
                            {
                                label: 'Loan Count',
                                data: data.loanTrends.map(d => d.value),
                                borderColor: '#28a745',
                                backgroundColor: 'rgba(40, 167, 69, 0.1)',
                                yAxisID: 'y'
                            },
                            {
                                label: 'Amount (₱)',
                                data: data.amountTrends.map(d => d.value),
                                borderColor: '#6610f2',
                                backgroundColor: 'rgba(102, 16, 242, 0.1)',
                                yAxisID: 'y1'
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        interaction: {
                            mode: 'index',
                            intersect: false,
                        },
                        scales: {
                            y: {
                                type: 'linear',
                                display: true,
                                position: 'left',
                                title: {
                                    display: true,
                                    text: 'Number of Loans'
                                }
                            },
                            y1: {
                                type: 'linear',
                                display: true,
                                position: 'right',
                                title: {
                                    display: true,
                                    text: 'Amount (₱)'
                                },
                                grid: {
                                    drawOnChartArea: false,
                                },
                            },
                        }
                    }
                });
            }
        }

        // Render payment charts
        function renderPaymentCharts(summary) {
            // Payment Method Chart
            const methodCtx = document.getElementById('paymentMethodChart')?.getContext('2d');
            if (methodCtx && summary.by_method) {
                new Chart(methodCtx, {
                    type: 'pie',
                    data: {
                        labels: Object.keys(summary.by_method),
                        datasets: [{
                            data: Object.values(summary.by_method).map(m => m.amount),
                            backgroundColor: ['#28a745', '#ffc107', '#17a2b8', '#6610f2']
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: { position: 'bottom' },
                            tooltip: {
                                callbacks: {
                                    label: (context) => {
                                        const method = summary.by_method[context.label];
                                        return `${context.label}: ₱${method.amount.toLocaleString()} (${method.count} payments)`;
                                    }
                                }
                            }
                        }
                    }
                });
            }
            
            // Payment Status Chart
            const statusCtx = document.getElementById('paymentStatusChart')?.getContext('2d');
            if (statusCtx && summary.by_status) {
                new Chart(statusCtx, {
                    type: 'bar',
                    data: {
                        labels: Object.keys(summary.by_status),
                        datasets: [{
                            label: 'Amount',
                            data: Object.values(summary.by_status).map(s => s.amount),
                            backgroundColor: ['#28a745', '#ffc107', '#dc3545', '#6c757d']
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    label: (context) => {
                                        const status = Object.values(summary.by_status)[context.dataIndex];
                                        return `₱${status.amount.toLocaleString()} (${status.count} payments)`;
                                    }
                                }
                            }
                        }
                    }
                });
            }
        }

        // Render customer charts
        function renderCustomerCharts(summary) {
            // Pension System Chart
            const pensionCtx = document.getElementById('pensionSystemChart')?.getContext('2d');
            if (pensionCtx && summary.by_system) {
                new Chart(pensionCtx, {
                    type: 'doughnut',
                    data: {
                        labels: Object.keys(summary.by_system),
                        datasets: [{
                            data: Object.values(summary.by_system),
                            backgroundColor: ['#6610f2', '#28a745', '#ffc107', '#dc3545', '#17a2b8']
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: { position: 'bottom' }
                        }
                    }
                });
            }
            
            // Geographic Chart
            const geoCtx = document.getElementById('geoChart')?.getContext('2d');
            if (geoCtx && summary.by_city) {
                const topCities = Object.entries(summary.by_city)
                    .sort((a, b) => b[1] - a[1])
                    .slice(0, 5);
                
                new Chart(geoCtx, {
                    type: 'bar',
                    data: {
                        labels: topCities.map(c => c[0]),
                        datasets: [{
                            label: 'Number of Customers',
                            data: topCities.map(c => c[1]),
                            backgroundColor: '#17a2b8'
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: { display: false }
                        }
                    }
                });
            }
        }

        // Filter loans
        function filterLoans() {
            const status = document.getElementById('statusFilter').value;
            loadReportData('loans', { status });
        }

        // Export report
        function exportReport() {
            const type = new URLSearchParams(window.location.search).get('type') || 'overview';
            const range = document.getElementById('dateRange').value;
            let startDate, endDate;
            
            if (range === 'custom') {
                startDate = document.getElementById('startDate').value;
                endDate = document.getElementById('endDate').value;
            } else {
                // Calculate dates based on range
                const today = new Date();
                endDate = today.toISOString().split('T')[0];
                
                switch(range) {
                    case 'today':
                        startDate = endDate;
                        break;
                    case 'week':
                        startDate = new Date(today.setDate(today.getDate() - 7)).toISOString().split('T')[0];
                        break;
                    case 'month':
                        startDate = new Date(today.setMonth(today.getMonth() - 1)).toISOString().split('T')[0];
                        break;
                    case 'quarter':
                        startDate = new Date(today.setMonth(today.getMonth() - 3)).toISOString().split('T')[0];
                        break;
                    case 'year':
                        startDate = new Date(today.setFullYear(today.getFullYear() - 1)).toISOString().split('T')[0];
                        break;
                }
            }
            
            // Determine which export to use
            let exportType = type;
            if (type === 'overview') {
                // For overview, default to loans export
                exportType = 'loans';
            }
            
            window.location.href = `/api/reports/export/${exportType}?startDate=${startDate}&endDate=${endDate}`;
        }

        // Utility functions
        function showLoading() {
            document.getElementById('loadingSpinner').classList.add('active');
        }
        
        function hideLoading() {
            document.getElementById('loadingSpinner').classList.remove('active');
        }
        
        function showError(message) {
            alert(message);
        }
    </script>
</body>
</html>