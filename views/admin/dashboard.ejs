<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        .stat-card {
            border-radius: 15px;
            border: none;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            overflow: hidden;
        }
        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
        }
        .activity-item {
            border-left: 3px solid #007bff;
            padding-left: 15px;
            margin-bottom: 15px;
            transition: all 0.3s ease;
        }
        .activity-item:hover {
            background-color: #f8f9fa;
            border-left-color: #0056b3;
        }
        .activity-item.admin { border-left-color: #dc3545; }
        .activity-item.manager { border-left-color: #ffc107; }
        .activity-item.employee { border-left-color: #28a745; }
        .activity-item.customer { border-left-color: #6c757d; }
        .user-badge {
            font-size: 0.7rem;
            padding: 3px 8px;
        }
        .recent-activity {
            max-height: 500px;
            overflow-y: auto;
        }
        .quick-action-card {
            background: white;
            border-radius: 10px;
            padding: 20px;
            text-align: center;
            border: 1px solid #e9ecef;
            transition: all 0.3s ease;
            height: 100%;
        }
        .quick-action-card:hover {
            border-color: #007bff;
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }
        .action-icon {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px;
            font-size: 24px;
            color: white;
        }
        .icon-primary { background: linear-gradient(135deg, #007bff 0%, #0056b3 100%); }
        .icon-success { background: linear-gradient(135deg, #28a745 0%, #1e7e34 100%); }
        .icon-warning { background: linear-gradient(135deg, #ffc107 0%, #e0a800 100%); }
        .icon-danger { background: linear-gradient(135deg, #dc3545 0%, #c82333 100%); }
        .table-hover tbody tr:hover {
            background-color: rgba(0, 123, 255, 0.05);
        }
        .loan-status-badge {
            font-size: 0.75rem;
            padding: 4px 8px;
        }
        .empty-state {
            padding: 2rem 1rem;
            text-align: center;
            color: #6c757d;
        }
        .empty-state i {
            font-size: 3rem;
            margin-bottom: 1rem;
            opacity: 0.5;
        }
        .nav-tabs .nav-link.active {
            font-weight: bold;
            border-bottom: 3px solid #007bff;
        }
        .calculation-result {
            background-color: #f8f9fa;
            border-radius: 5px;
            padding: 10px;
            margin-top: 10px;
        }
        .form-section {
            background: #f8f9fa;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 15px;
        }
    </style>
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/dashboard">
                <i class="bi bi-cash-coin me-2"></i> Millenium Cash
            </a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link active" href="/dashboard">Dashboard</a>
                <a class="nav-link" href="/admin/users">User Management</a>
                <a class="nav-link" href="/admin/register">Register Staff</a>
                <a class="nav-link" href="/loans">Loan Management</a>
                <a class="nav-link" href="/admin/reports">Reports</a>
                <a class="nav-link" href="/profile">Profile</a>
                <a class="nav-link" href="/logout">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container my-4">
        <!-- Header -->
        <div class="row mb-4">
            <div class="col-md-8">
                <h2 class="mb-1">Admin Dashboard</h2>
                <p class="text-muted mb-0">System overview and management console</p>
            </div>
            <div class="col-md-4 text-end">
                <div class="bg-primary text-white p-2 rounded d-inline-block">
                    <small>Admin Access</small>
                    <div class="fw-bold">ADMIN-<%= user.user_id.toString().padStart(4, '0') %></div>
                </div>
            </div>
        </div>

        <!-- Statistics Cards -->
        <div class="row mb-4">
            <div class="col-xl-3 col-md-6 mb-3">
                <div class="card stat-card bg-primary text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h2 class="mb-0"><%= stats.totalUsers || 0 %></h2>
                                <p class="mb-0 fw-light">Total Users</p>
                                <div class="progress mt-2 bg-white bg-opacity-25" style="height: 4px;">
                                    <div class="progress-bar bg-white" style="width: <%= Math.min((stats.totalUsers || 0) * 5, 100) %>%"></div>
                                </div>
                            </div>
                            <i class="bi bi-people-fill display-6 opacity-50"></i>
                        </div>
                        <div class="mt-3">
                            <small class="opacity-75">
                                <i class="bi bi-graph-up me-1"></i>
                                Active system users
                            </small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6 mb-3">
                <div class="card stat-card bg-success text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h2 class="mb-0"><%= stats.totalLoans || 0 %></h2>
                                <p class="mb-0 fw-light">Total Loans</p>
                                <div class="progress mt-2 bg-white bg-opacity-25" style="height: 4px;">
                                    <div class="progress-bar bg-white" style="width: <%= Math.min((stats.totalLoans || 0) * 2, 100) %>%"></div>
                                </div>
                            </div>
                            <i class="bi bi-clipboard-data display-6 opacity-50"></i>
                        </div>
                        <div class="mt-3">
                            <small class="opacity-75">
                                <i class="bi bi-cash-coin me-1"></i>
                                All loan applications
                            </small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6 mb-3">
                <div class="card stat-card bg-warning text-dark">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h2 class="mb-0"><%= stats.pendingLoans || 0 %></h2>
                                <p class="mb-0 fw-light">Pending Loans</p>
                                <div class="progress mt-2 bg-dark bg-opacity-25" style="height: 4px;">
                                    <div class="progress-bar bg-dark" style="width: <%= Math.min((stats.pendingLoans || 0) * 10, 100) %>%"></div>
                                </div>
                            </div>
                            <i class="bi bi-clock-history display-6 opacity-50"></i>
                        </div>
                        <div class="mt-3">
                            <small class="opacity-75">
                                <i class="bi bi-exclamation-triangle me-1"></i>
                                Awaiting approval
                            </small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6 mb-3">
                <div class="card stat-card bg-info text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h2 class="mb-0">₱<%= (stats.totalDisbursed || 0).toLocaleString() %></h2>
                                <p class="mb-0 fw-light">Total Disbursed</p>
                                <div class="progress mt-2 bg-white bg-opacity-25" style="height: 4px;">
                                    <div class="progress-bar bg-white" style="width: <%= Math.min((stats.totalDisbursed || 0) / 1000000, 100) %>%"></div>
                                </div>
                            </div>
                            <i class="bi bi-cash-stack display-6 opacity-50"></i>
                        </div>
                        <div class="mt-3">
                            <small class="opacity-75">
                                <i class="bi bi-currency-exchange me-1"></i>
                                Total amount disbursed
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions & Recent Activity -->
        <div class="row mb-4">
            <!-- Quick Actions -->
            <div class="col-lg-6 mb-4">
                <div class="card h-100">
                    <div class="card-header bg-white">
                        <h5 class="mb-0"><i class="bi bi-lightning-fill me-2 text-warning"></i>Quick Actions</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="quick-action-card">
                                    <div class="action-icon icon-primary">
                                        <i class="bi bi-people-fill"></i>
                                    </div>
                                    <h6 class="fw-bold">User Management</h6>
                                    <p class="text-muted small mb-3">Manage all system users</p>
                                    <a href="/admin/users" class="btn btn-primary btn-sm w-100">
                                        Manage Users
                                    </a>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="quick-action-card">
                                    <div class="action-icon icon-success">
                                        <i class="bi bi-person-plus"></i>
                                    </div>
                                    <h6 class="fw-bold">Register Staff</h6>
                                    <p class="text-muted small mb-3">Add new employees/managers</p>
                                    <a href="/admin/register" class="btn btn-success btn-sm w-100">
                                        Add Staff
                                    </a>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="quick-action-card">
                                    <div class="action-icon icon-warning">
                                        <i class="bi bi-clipboard-check"></i>
                                    </div>
                                    <h6 class="fw-bold">Loan Management</h6>
                                    <p class="text-muted small mb-3">Review and edit all loans</p>
                                    <a href="/loans" class="btn btn-warning btn-sm w-100">
                                        Manage Loans
                                    </a>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="quick-action-card">
                                    <div class="action-icon icon-danger">
                                        <i class="bi bi-graph-up"></i>
                                    </div>
                                    <h6 class="fw-bold">System Reports</h6>
                                    <p class="text-muted small mb-3">View analytics & reports</p>
                                    <a href="/admin/reports" class="btn btn-danger btn-sm w-100">
                                        View Reports
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recent Activity -->
            <div class="col-lg-6 mb-4">
                <div class="card h-100">
                    <div class="card-header bg-white">
                        <h5 class="mb-0"><i class="bi bi-activity me-2 text-primary"></i>Recent System Activity</h5>
                    </div>
                    <div class="card-body recent-activity">
                        <% if (recentActivities && recentActivities.length > 0) { %>
                            <% recentActivities.forEach(activity => { %>
                            <div class="activity-item <%= activity.user_type || 'customer' %>">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div class="flex-grow-1">
                                        <div class="d-flex align-items-center mb-1">
                                            <strong class="me-2"><%= activity.full_name %></strong>
                                            <span class="badge user-badge bg-<%= 
                                                activity.user_type === 'admin' ? 'danger' : 
                                                activity.user_type === 'manager' ? 'warning' : 
                                                activity.user_type === 'employee' ? 'success' : 'secondary'
                                            %>">
                                                <%= activity.user_type || 'customer' %>
                                            </span>
                                        </div>
                                        <p class="mb-1 small"><%= activity.description %></p>
                                        <small class="text-muted">
                                            <i class="bi bi-clock me-1"></i>
                                            <%= new Date(activity.created_at).toLocaleString() %>
                                        </small>
                                    </div>
                                    <div class="text-end">
                                        <small class="text-muted d-block">
                                            <i class="bi bi-<%= 
                                                activity.action === 'LOGIN' ? 'box-arrow-in-right' : 
                                                activity.action === 'CREATE_LOAN' ? 'plus-circle' : 
                                                activity.action === 'CREATE_USER' ? 'person-plus' : 'gear'
                                            %> me-1"></i>
                                            <%= activity.action %>
                                        </small>
                                    </div>
                                </div>
                            </div>
                            <% }); %>
                        <% } else { %>
                            <div class="empty-state">
                                <i class="bi bi-inbox"></i>
                                <p class="mb-0">No recent activity</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Loans & User Management -->
        <div class="row">
            <!-- Recent Loans -->
            <div class="col-lg-8 mb-4">
                <div class="card">
                    <div class="card-header bg-white">
                        <h5 class="mb-0"><i class="bi bi-clipboard-data me-2 text-primary"></i>Recent Loan Applications</h5>
                    </div>
                    <div class="card-body">
                        <% if (recentLoans && recentLoans.length > 0) { %>
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Loan Details</th>
                                            <th>Customer</th>
                                            <th>Status</th>
                                            <th>Date</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% recentLoans.forEach(loan => { %>
                                        <tr>
                                            <td>
                                                <div class="fw-bold">₱<%= parseFloat(loan.loan_amount).toLocaleString() %></div>
                                                <small class="text-muted text-capitalize"><%= loan.loan_type || 'regular' %></small>
                                            </td>
                                            <td>
                                                <div class="fw-bold"><%= loan.borrower_name %></div>
                                                <small class="text-muted">
                                                    <i class="bi bi-person me-1"></i>
                                                    <%= loan.borrower_id %>
                                                </small>
                                            </td>
                                            <td>
                                                <span class="badge loan-status-badge bg-<%= 
                                                    loan.status === 'pending' ? 'warning' : 
                                                    loan.status === 'approved' ? 'success' : 
                                                    loan.status === 'rejected' ? 'danger' : 
                                                    loan.status === 'disbursed' ? 'info' : 'secondary'
                                                %>">
                                                    <%= loan.status.toUpperCase() %>
                                                </span>
                                            </td>
                                            <td>
                                                <small><%= new Date(loan.applied_date).toLocaleDateString() %></small>
                                            </td>
                                            <td>
                                                <div class="btn-group btn-group-sm">
                                                    <button class="btn btn-outline-primary" 
                                                            onclick="viewLoan(<%= loan.loan_id %>)"
                                                            data-bs-toggle="tooltip" title="View Details">
                                                        <i class="bi bi-eye"></i>
                                                    </button>
                                                    <button class="btn btn-outline-warning" 
                                                            onclick="editLoan(<%= loan.loan_id %>)"
                                                            data-bs-toggle="tooltip" title="Edit Loan">
                                                        <i class="bi bi-pencil"></i>
                                                    </button>
                                                    <% if (loan.status === 'pending') { %>
                                                    <button class="btn btn-outline-success" 
                                                            onclick="approveLoan(<%= loan.loan_id %>)"
                                                            data-bs-toggle="tooltip" title="Approve Loan">
                                                        <i class="bi bi-check-lg"></i>
                                                    </button>
                                                    <% } %>
                                                </div>
                                            </td>
                                        </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                            <div class="text-end mt-3">
                                <a href="/loans" class="btn btn-outline-primary btn-sm">
                                    View All Loans <i class="bi bi-arrow-right ms-1"></i>
                                </a>
                            </div>
                        <% } else { %>
                            <div class="empty-state">
                                <i class="bi bi-clipboard-x"></i>
                                <p class="mb-0">No recent loan applications</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- User Statistics -->
            <div class="col-lg-4 mb-4">
                <div class="card">
                    <div class="card-header bg-white">
                        <h5 class="mb-0"><i class="bi bi-people me-2 text-success"></i>User Statistics</h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group list-group-flush">
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="bi bi-person-gear text-danger me-2"></i>
                                    <span>Administrators</span>
                                </div>
                                <span class="badge bg-danger rounded-pill"><%= userStats.admins || 0 %></span>
                            </div>
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="bi bi-person-badge text-warning me-2"></i>
                                    <span>Managers</span>
                                </div>
                                <span class="badge bg-warning rounded-pill"><%= userStats.managers || 0 %></span>
                            </div>
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="bi bi-person-check text-success me-2"></i>
                                    <span>Employees</span>
                                </div>
                                <span class="badge bg-success rounded-pill"><%= userStats.employees || 0 %></span>
                            </div>
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="bi bi-people text-secondary me-2"></i>
                                    <span>Customers</span>
                                </div>
                                <span class="badge bg-secondary rounded-pill"><%= userStats.customers || 0 %></span>
                            </div>
                        </div>
                        <div class="mt-3 text-center">
                            <a href="/admin/users" class="btn btn-outline-success btn-sm">
                                <i class="bi bi-people-fill me-1"></i>Manage All Users
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Loan Edit Modal -->
    <div class="modal fade" id="editLoanModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Loan Details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="editLoanContent">
                    <!-- Dynamic content will be loaded here -->
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let editLoanModal = null;

        // Initialize modals when DOM is loaded
        document.addEventListener('DOMContentLoaded', function() {
            editLoanModal = new bootstrap.Modal(document.getElementById('editLoanModal'));
            
            // Initialize tooltips
            const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });
        });

        // View loan details
        function viewLoan(loanId) {
            window.location.href = `/loans?view=${loanId}`;
        }

        // Edit loan - No loading modal
        async function editLoan(loanId) {
            try {
                // Fetch loan details from API
                const response = await fetch(`/api/loan/${loanId}`);
                const data = await response.json();

                if (!data.success) {
                    throw new Error(data.message);
                }

                const loan = data.loan;
                
                // Create edit form
                const modalContent = document.getElementById('editLoanContent');
                modalContent.innerHTML = `
                    <form id="editLoanForm" onsubmit="updateLoan(event, ${loanId})">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-section">
                                    <h6><i class="bi bi-info-circle"></i> Basic Information</h6>
                                    <div class="mb-3">
                                        <label class="form-label">Borrower</label>
                                        <input type="text" class="form-control" value="${loan.borrower_name}" readonly>
                                        <small class="text-muted">${loan.borrower_email} | ${loan.contact_number}</small>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Pension Number</label>
                                        <input type="text" class="form-control" value="${loan.pension_number}" readonly>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Monthly Pension</label>
                                        <input type="text" class="form-control" value="₱${parseFloat(loan.monthly_pension || 0).toLocaleString()}" readonly>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-section">
                                    <h6><i class="bi bi-cash-coin"></i> Loan Details</h6>
                                    <div class="mb-3">
                                        <label class="form-label">Loan Amount (₱)</label>
                                        <input type="number" class="form-control" id="loanAmount" name="loan_amount" 
                                               value="${loan.loan_amount}" min="1000" step="100" required>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Interest Rate (%)</label>
                                        <input type="number" class="form-control" id="interestRate" name="interest_rate" 
                                               value="${loan.interest_rate}" min="1" max="20" step="0.1" required>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Duration (Months)</label>
                                        <input type="number" class="form-control" id="durationMonths" name="duration_months" 
                                               value="${loan.duration_months}" min="1" max="36" required>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-section">
                                    <h6><i class="bi bi-card-text"></i> Loan Purpose</h6>
                                    <div class="mb-3">
                                        <label class="form-label">Purpose</label>
                                        <textarea class="form-control" name="purpose" rows="3">${loan.purpose || ''}</textarea>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Purpose Category</label>
                                        <select class="form-select" name="purpose_category">
                                            <option value="">Select Category</option>
                                            <option value="emergency" ${loan.purpose_category === 'emergency' ? 'selected' : ''}>Emergency</option>
                                            <option value="education" ${loan.purpose_category === 'education' ? 'selected' : ''}>Education</option>
                                            <option value="housing" ${loan.purpose_category === 'housing' ? 'selected' : ''}>Housing</option>
                                            <option value="livelihood" ${loan.purpose_category === 'livelihood' ? 'selected' : ''}>Livelihood</option>
                                            <option value="medical" ${loan.purpose_category === 'medical' ? 'selected' : ''}>Medical</option>
                                            <option value="other" ${loan.purpose_category === 'other' ? 'selected' : ''}>Other</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-section">
                                    <h6><i class="bi bi-gear"></i> Loan Settings</h6>
                                    <div class="mb-3">
                                        <label class="form-label">Disbursement Method</label>
                                        <select class="form-select" name="disbursement_method">
                                            <option value="">Select Method</option>
                                            <option value="bank_transfer" ${loan.disbursement_method === 'bank_transfer' ? 'selected' : ''}>Bank Transfer</option>
                                            <option value="cash" ${loan.disbursement_method === 'cash' ? 'selected' : ''}>Cash</option>
                                            <option value="check" ${loan.disbursement_method === 'check' ? 'selected' : ''}>Check</option>
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Status</label>
                                        <select class="form-select" name="status">
                                            <option value="pending" ${loan.status === 'pending' ? 'selected' : ''}>Pending</option>
                                            <option value="approved" ${loan.status === 'approved' ? 'selected' : ''}>Approved</option>
                                            <option value="rejected" ${loan.status === 'rejected' ? 'selected' : ''}>Rejected</option>
                                            <option value="disbursed" ${loan.status === 'disbursed' ? 'selected' : ''}>Disbursed</option>
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Admin Notes</label>
                                        <textarea class="form-control" name="notes" rows="2" placeholder="Add any notes or comments...">${loan.notes || ''}</textarea>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Calculation Results -->
                        <div class="form-section">
                            <h6><i class="bi bi-calculator"></i> Payment Calculation</h6>
                            <div class="row">
                                <div class="col-md-4">
                                    <div class="calculation-result">
                                        <small class="text-muted">Monthly Payment</small>
                                        <div class="fw-bold" id="calculatedMonthly">₱${parseFloat(loan.monthly_payment || 0).toLocaleString()}</div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="calculation-result">
                                        <small class="text-muted">Total Payable</small>
                                        <div class="fw-bold" id="calculatedTotal">₱${parseFloat(loan.total_payable || 0).toLocaleString()}</div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="calculation-result">
                                        <small class="text-muted">Total Interest</small>
                                        <div class="fw-bold" id="calculatedInterest">₱${parseFloat(loan.total_interest || 0).toLocaleString()}</div>
                                    </div>
                                </div>
                            </div>
                            <button type="button" class="btn btn-outline-primary btn-sm mt-2" onclick="recalculatePayments()">
                                <i class="bi bi-arrow-clockwise"></i> Recalculate
                            </button>
                        </div>

                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-check-lg"></i> Update Loan
                            </button>
                        </div>
                    </form>
                `;

                // Show edit modal
                if (editLoanModal) {
                    editLoanModal.show();
                }

                // Add event listeners for real-time calculation
                document.getElementById('loanAmount').addEventListener('input', recalculatePayments);
                document.getElementById('interestRate').addEventListener('input', recalculatePayments);
                document.getElementById('durationMonths').addEventListener('input', recalculatePayments);

            } catch (error) {
                console.error('Error loading loan details:', error);
                alert('Error loading loan details: ' + error.message);
            }
        }

        // Recalculate payment amounts
        function recalculatePayments() {
            const loanAmount = parseFloat(document.getElementById('loanAmount').value) || 0;
            const interestRate = parseFloat(document.getElementById('interestRate').value) || 0;
            const durationMonths = parseInt(document.getElementById('durationMonths').value) || 1;

            if (loanAmount > 0 && interestRate > 0 && durationMonths > 0) {
                const monthlyRate = interestRate / 100 / 12;
                const monthlyPayment = loanAmount * monthlyRate * Math.pow(1 + monthlyRate, durationMonths) / 
                                      (Math.pow(1 + monthlyRate, durationMonths) - 1);
                const totalPayable = monthlyPayment * durationMonths;
                const totalInterest = totalPayable - loanAmount;

                document.getElementById('calculatedMonthly').textContent = '₱' + monthlyPayment.toFixed(2);
                document.getElementById('calculatedTotal').textContent = '₱' + totalPayable.toFixed(2);
                document.getElementById('calculatedInterest').textContent = '₱' + totalInterest.toFixed(2);
            }
        }

        // Update loan
        async function updateLoan(event, loanId) {
            event.preventDefault();
            
            const formData = new FormData(event.target);
            const data = Object.fromEntries(formData.entries());

            try {
                const response = await fetch(`/api/loan/${loanId}`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(data)
                });

                const result = await response.json();

                if (result.success) {
                    alert('Loan updated successfully!');
                    // Close modal and refresh page
                    if (editLoanModal) {
                        editLoanModal.hide();
                    }
                    location.reload();
                } else {
                    throw new Error(result.message);
                }
            } catch (error) {
                alert('Error updating loan: ' + error.message);
            }
        }

        // Approve loan
        function approveLoan(loanId) {
            if (confirm('Are you sure you want to approve this loan application?')) {
                fetch(`/approve-loan/${loanId}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        status: 'approved'
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Loan approved successfully!');
                        location.reload();
                    } else {
                        alert('Error approving loan: ' + data.message);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Error approving loan application.');
                });
            }
        }
    </script>
</body>
</html>