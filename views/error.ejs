<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error - Pension Loan System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6 text-center">
                <i class="bi bi-exclamation-triangle text-warning display-1"></i>
                <h1 class="mt-3">Oops! Something went wrong</h1>
                <p class="lead text-muted"><%= message %></p>
                
                <% if (error && error.stack) { %>
                    <div class="alert alert-danger text-start">
                        <pre class="mb-0"><%= error.stack %></pre>
                    </div>
                <% } %>
                
                <div class="mt-4">
                    <a href="/" class="btn btn-primary me-2">Go Home</a>
                    <a href="/dashboard" class="btn btn-outline-primary">Dashboard</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>