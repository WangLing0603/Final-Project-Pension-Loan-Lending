<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/dashboard">
                <i class="bi bi-cash-coin me-2"></i> Pension Loan System
            </a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/dashboard">Dashboard</a>
                <a class="nav-link" href="/loans">Loan Applications</a>
                <a class="nav-link active" href="/manager/team">Team Management</a>
                <a class="nav-link" href="/profile">Profile</a>
                <a class="nav-link" href="/logout">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container my-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="mb-1">Team Management</h2>
                <p class="text-muted mb-0">Manage your team members and their performance</p>
            </div>
            <div class="bg-warning text-dark p-2 rounded">
                <small>Manager Access</small>
                <div class="fw-bold">MGR-<%= user.user_id.toString().padStart(4, '0') %></div>
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-people-fill me-2"></i>Team Members</h5>
            </div>
            <div class="card-body">
                <% if (employees && employees.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Employee</th>
                                    <th>Email</th>
                                    <th>Status</th>
                                    <th>Join Date</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% employees.forEach(employee => { %>
                                <tr>
                                    <td>
                                        <div class="fw-bold"><%= employee.full_name %></div>
                                        <small class="text-muted">EMP-<%= employee.user_id.toString().padStart(4, '0') %></small>
                                    </td>
                                    <td><%= employee.email %></td>
                                    <td>
                                        <span class="badge bg-<%= employee.is_active ? 'success' : 'secondary' %>">
                                            <%= employee.is_active ? 'Active' : 'Inactive' %>
                                        </span>
                                    </td>
                                    <td><%= new Date(employee.created_at).toLocaleDateString() %></td>
                                    <td>
                                        <a href="/manager/employee/<%= employee.user_id %>" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye"></i> View
                                        </a>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-people display-1 opacity-25"></i>
                        <h5 class="mt-3">No Team Members</h5>
                        <p>There are no employees in your team yet.</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>