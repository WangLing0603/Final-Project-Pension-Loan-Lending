<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Millenium Cash</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        .payment-card { border-left: 4px solid #28a745; border-radius: 8px; }
        .payment-card.pending { border-left-color: #ffc107; }
        .payment-card.partial { border-left-color: #17a2b8; }
        .payment-card.overdue { border-left-color: #dc3545; }
        .stat-card { border-radius: 10px; }
    </style>
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/dashboard">
                <i class="bi bi-cash-coin me-2"></i>Millenium Cash
            </a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/dashboard">Dashboard</a>
                <a class="nav-link" href="/loans">Loan Applications</a>
                <a class="nav-link active" href="/employee/payments">Payment Posting</a>
                <a class="nav-link" href="/employee/pension-withdrawals">Pension Withdrawals</a>
                <a class="nav-link" href="/employee/collection-postings">Collection Postings</a>
                <a class="nav-link" href="/profile">Profile</a>
                <a class="nav-link" href="/logout">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container my-4">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="mb-1"><%= title %></h2>
                <p class="text-muted mb-0">Post and manage loan payments</p>
            </div>
            <div>
                <a href="/loans" class="btn btn-primary">
                    <i class="bi bi-search me-2"></i>Find Loan to Post
                </a>
            </div>
        </div>

        <!-- Statistics Cards -->
        <div class="row mb-4">
            <div class="col-xl-2 col-md-4 mb-3">
                <div class="card stat-card bg-primary text-white">
                    <div class="card-body text-center">
                        <h4 class="mb-0"><%= stats.total_payments || 0 %></h4>
                        <small>Total Payments</small>
                    </div>
                </div>
            </div>
            <div class="col-xl-2 col-md-4 mb-3">
                <div class="card stat-card bg-success text-white">
                    <div class="card-body text-center">
                        <h4 class="mb-0">₱<%= (stats.total_collected || 0).toLocaleString() %></h4>
                        <small>Amount Collected</small>
                    </div>
                </div>
            </div>
            <div class="col-xl-2 col-md-4 mb-3">
                <div class="card stat-card bg-warning text-dark">
                    <div class="card-body text-center">
                        <h4 class="mb-0"><%= stats.pending_count || 0 %></h4>
                        <small>Pending</small>
                    </div>
                </div>
            </div>
            <div class="col-xl-2 col-md-4 mb-3">
                <div class="card stat-card bg-danger text-white">
                    <div class="card-body text-center">
                        <h4 class="mb-0"><%= stats.overdue_count || 0 %></h4>
                        <small>Overdue</small>
                    </div>
                </div>
            </div>
            <div class="col-xl-4 col-md-8 mb-3">
                <div class="card stat-card bg-info text-white">
                    <div class="card-body text-center">
                        <h4 class="mb-0"><%= stats.paid_count || 0 %></h4>
                        <small>Successfully Posted Payments</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filters -->
        <div class="card mb-4">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <h6 class="mb-2">Filter Payments:</h6>
                        <div class="btn-group" role="group">
                            <a href="/employee/payments" class="btn btn-outline-primary <%= currentFilter === 'all' ? 'active' : '' %>">All</a>
                            <a href="/employee/payments?status=paid" class="btn btn-outline-success <%= currentFilter === 'paid' ? 'active' : '' %>">Paid</a>
                            <a href="/employee/payments?status=pending" class="btn btn-outline-warning <%= currentFilter === 'pending' ? 'active' : '' %>">Pending</a>
                            <a href="/employee/payments?status=overdue" class="btn btn-outline-danger <%= currentFilter === 'overdue' ? 'active' : '' %>">Overdue</a>
                        </div>
                    </div>
                    <div class="col-md-6 text-end">
                        <div class="btn-group" role="group">
                            <a href="/employee/payments?date=today" class="btn btn-outline-secondary <%= dateFilter === 'today' ? 'active' : '' %>">Today</a>
                            <a href="/employee/payments?date=week" class="btn btn-outline-secondary <%= dateFilter === 'week' ? 'active' : '' %>">This Week</a>
                            <a href="/employee/payments?date=month" class="btn btn-outline-secondary <%= dateFilter === 'month' ? 'active' : '' %>">This Month</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Payments Table -->
        <div class="card">
            <div class="card-header bg-white">
                <h5 class="mb-0">
                    <i class="bi bi-cash-stack me-2"></i>
                    Payment Records
                </h5>
            </div>
            <div class="card-body">
                <% if (payments.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Receipt No.</th>
                                    <th>Customer</th>
                                    <th>Loan ID</th>
                                    <th>Amount</th>
                                    <th>Method</th>
                                    <th>Status</th>
                                    <th>Date</th>
                                    <th>Posted By</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% payments.forEach(payment => { %>
                                <tr>
                                    <td>
                                        <% if (payment.receipt_number) { %>
                                        <strong><%= payment.receipt_number %></strong>
                                        <% } else { %>
                                        <span class="text-muted">Pending</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <div class="fw-bold"><%= payment.first_name %> <%= payment.last_name %></div>
                                        <small class="text-muted"><%= payment.pension_number %></small>
                                    </td>
                                    <td>#<%= payment.loan_id %></td>
                                    <td>
                                        <strong>₱<%= parseFloat(payment.amount_paid).toLocaleString() %></strong>
                                        <% if (payment.amount_paid < payment.amount_due) { %>
                                        <br><small class="text-warning">Due: ₱<%= parseFloat(payment.amount_due).toLocaleString() %></small>
                                        <% } %>
                                    </td>
                                    <td class="text-capitalize"><%= payment.payment_method.replace('_', ' ') %></td>
                                    <td>
                                        <span class="badge bg-<%= 
                                            payment.payment_status === 'paid' ? 'success' : 
                                            payment.payment_status === 'pending' ? 'warning' : 
                                            payment.payment_status === 'partial' ? 'info' : 'danger'
                                        %>">
                                            <%= payment.payment_status %>
                                        </span>
                                    </td>
                                    <td><%= new Date(payment.payment_date).toLocaleDateString() %></td>
                                    <td><%= payment.posted_by_name %></td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a href="/employee/payment-receipt/<%= payment.payment_id %>" 
                                               class="btn btn-outline-primary" title="View Receipt">
                                                <i class="bi bi-receipt"></i>
                                            </a>
                                            <% if (payment.payment_status === 'pending') { %>
                                            <a href="/employee/post-payment/<%= payment.loan_id %>" 
                                               class="btn btn-outline-success" title="Edit Payment">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="text-center py-5">
                        <i class="bi bi-cash-stack display-1 text-muted"></i>
                        <h4 class="mt-3 text-muted">No Payments Found</h4>
                        <p class="text-muted mb-4">
                            <% if (currentFilter !== 'all') { %>
                                No <%= currentFilter %> payments found.
                            <% } else { %>
                                No payment records found in the system.
                            <% } %>
                        </p>
                        <a href="/loans" class="btn btn-primary">
                            <i class="bi bi-search me-2"></i>Find Loan to Post Payment
                        </a>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>