<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Millenium Cash</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        .form-container {
            max-width: 800px;
            margin: 0 auto;
        }
        .form-card {
            background: white;
            border-radius: 15px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
            overflow: hidden;
        }
        .form-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 25px 30px;
        }
        .form-body {
            padding: 30px;
        }
        .customer-info {
            background: #f8f9fa;
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 20px;
            border-left: 4px solid #28a745;
        }
        .amount-preset {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 10px;
        }
        .preset-btn {
            flex: 1;
            text-align: center;
            padding: 10px;
            border: 1px solid #dee2e6;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        .preset-btn:hover {
            background: #e9ecef;
            transform: translateY(-2px);
        }
        .preset-btn.selected {
            background: #28a745;
            color: white;
            border-color: #28a745;
        }
        .customer-select {
            cursor: pointer;
        }
        .customer-card {
            transition: all 0.3s ease;
        }
        .customer-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }
    </style>
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/dashboard">
                <i class="bi bi-cash-coin me-2"></i>Millenium Cash
            </a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/dashboard">Dashboard</a>
                <a class="nav-link" href="/employee/pension-withdrawals">Pension Withdrawals</a>
                <a class="nav-link active" href="/employee/create-withdrawal">Create Withdrawal</a>
                <a class="nav-link" href="/logout">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container my-4">
        <div class="form-container">
            <div class="form-card">
                <div class="form-header">
                    <h2 class="mb-1"><i class="bi bi-cash-withdrawal me-2"></i>Create Pension Withdrawal</h2>
                    <p class="mb-0 opacity-75">Process a new pension withdrawal request</p>
                </div>
                
                <div class="form-body">
                    <!-- Alert Messages -->
                    <% if (error) { %>
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    <% } %>
                    
                    <% if (success) { %>
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i><%= success %>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    <% } %>

                    <form action="/employee/process-withdrawal" method="POST" id="withdrawalForm">
                        <!-- Customer Selection -->
                        <div class="mb-4">
                            <label class="form-label fw-bold">Select Customer *</label>
                            <select class="form-select" name="customer_id" id="customerId" required onchange="loadCustomerDetails()">
                                <option value="">-- Select a customer --</option>
                                <% if (customers && customers.length > 0) { %>
                                    <% customers.forEach(customer => { %>
                                        <option value="<%= customer.customer_id %>" <%= customer_id && customer.customer_id == customer_id ? 'selected' : '' %>>
                                            <%= customer.display_name %>
                                        </option>
                                    <% }); %>
                                <% } %>
                            </select>
                        </div>

                        <!-- Customer Details (dynamic) -->
                        <div id="customerDetails" style="display: none;" class="customer-info">
                            <div class="row">
                                <div class="col-md-6">
                                    <small class="text-muted">Pension Number</small>
                                    <div class="fw-bold" id="displayPensionNumber">-</div>
                                </div>
                                <div class="col-md-6">
                                    <small class="text-muted">Pension System</small>
                                    <div class="fw-bold" id="displayPensionSystem">-</div>
                                </div>
                                <div class="col-md-6 mt-2">
                                    <small class="text-muted">Monthly Pension</small>
                                    <div class="fw-bold text-success" id="displayMonthlyPension">₱0.00</div>
                                </div>
                                <div class="col-md-6 mt-2">
                                    <small class="text-muted">Maximum Withdrawal</small>
                                    <div class="fw-bold text-warning" id="displayMaxWithdrawal">₱0.00</div>
                                </div>
                            </div>
                        </div>

                        <!-- Withdrawal Amount -->
                        <div class="mb-4">
                            <label class="form-label fw-bold">Withdrawal Amount *</label>
                            <input type="number" step="100" class="form-control form-control-lg" 
                                   name="withdrawal_amount" id="withdrawalAmount" required
                                   placeholder="Enter amount in PHP">
                            
                            <div class="amount-preset">
                                <div class="preset-btn" onclick="setAmount(1000)">₱1,000</div>
                                <div class="preset-btn" onclick="setAmount(2000)">₱2,000</div>
                                <div class="preset-btn" onclick="setAmount(5000)">₱5,000</div>
                                <div class="preset-btn" onclick="setAmount(10000)">₱10,000</div>
                                <div class="preset-btn" onclick="setAmount('custom')">Custom</div>
                            </div>
                            <small class="text-muted">Maximum withdrawal amount is your monthly pension</small>
                        </div>

                        <!-- Withdrawal Method -->
                        <div class="mb-4">
                            <label class="form-label fw-bold">Withdrawal Method *</label>
                            <select class="form-select" name="withdrawal_method" required>
                                <option value="">Select method...</option>
                                <option value="cash_pickup">💵 Cash Pickup</option>
                                <option value="bank_transfer">🏦 Bank Transfer</option>
                                <option value="gcash">📱 GCash</option>
                                <option value="paymaya">📱 PayMaya</option>
                                <option value="check">📝 Check</option>
                            </select>
                        </div>

                        <!-- Withdrawal Date -->
                        <div class="mb-4">
                            <label class="form-label fw-bold">Withdrawal Date *</label>
                            <input type="date" class="form-control" name="withdrawal_date" 
                                   value="<%= new Date().toISOString().split('T')[0] %>" required>
                        </div>

                        <!-- Notes -->
                        <div class="mb-4">
                            <label class="form-label">Notes (Optional)</label>
                            <textarea class="form-control" name="notes" rows="3" 
                                      placeholder="Any additional notes about this withdrawal"></textarea>
                        </div>

                        <!-- Important Information -->
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle-fill me-2"></i>
                            <strong>Important Information:</strong>
                            <ul class="mb-0 mt-2">
                                <li>Withdrawal will be created with "Pending" status</li>
                                <li>You can update status to "Processing" or "Completed" later</li>
                                <li>Once completed, you can create a collection posting</li>
                                <li>A receipt will be generated for completed withdrawals</li>
                            </ul>
                        </div>

                        <!-- Form Actions -->
                        <div class="d-flex gap-3">
                            <a href="/employee/pension-withdrawals" class="btn btn-secondary flex-grow-1">
                                <i class="bi bi-arrow-left me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-primary flex-grow-1" id="submitBtn">
                                <i class="bi bi-check-circle me-2"></i>Create Withdrawal
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let currentCustomer = null;

        // Load customer details when selected
        function loadCustomerDetails() {
            const customerId = document.getElementById('customerId').value;
            if (!customerId) {
                document.getElementById('customerDetails').style.display = 'none';
                return;
            }

            fetch(`/api/customer/${customerId}/pension-details`)
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        currentCustomer = data.data;
                        document.getElementById('customerDetails').style.display = 'block';
                        document.getElementById('displayPensionNumber').innerHTML = currentCustomer.pension_number || 'N/A';
                        document.getElementById('displayPensionSystem').innerHTML = currentCustomer.pension_system || 'N/A';
                        document.getElementById('displayMonthlyPension').innerHTML = `₱${parseFloat(currentCustomer.monthly_pension || 0).toLocaleString()}`;
                        document.getElementById('displayMaxWithdrawal').innerHTML = `₱${parseFloat(currentCustomer.max_withdrawal || 0).toLocaleString()}`;
                        
                        // Set max attribute on amount input
                        const amountInput = document.getElementById('withdrawalAmount');
                        amountInput.max = currentCustomer.monthly_pension || 0;
                        amountInput.placeholder = `Max: ₱${parseFloat(currentCustomer.monthly_pension || 0).toLocaleString()}`;
                    }
                })
                .catch(error => {
                    console.error('Error loading customer details:', error);
                });
        }

        // Set preset amount
        function setAmount(amount) {
            const amountInput = document.getElementById('withdrawalAmount');
            if (amount === 'custom') {
                amountInput.value = '';
                amountInput.focus();
            } else {
                amountInput.value = amount;
            }
            
            // Update preset button styles
            document.querySelectorAll('.preset-btn').forEach(btn => {
                btn.classList.remove('selected');
            });
            if (amount !== 'custom') {
                event.currentTarget.classList.add('selected');
            }
        }

        // Validate amount before submit
        document.getElementById('withdrawalForm').addEventListener('submit', function(e) {
            const amount = parseFloat(document.getElementById('withdrawalAmount').value);
            const maxAmount = parseFloat(currentCustomer?.monthly_pension || 0);
            
            if (amount <= 0) {
                e.preventDefault();
                alert('Please enter a valid withdrawal amount');
                return false;
            }
            
            if (amount > maxAmount) {
                e.preventDefault();
                alert(`Withdrawal amount cannot exceed monthly pension of ₱${maxAmount.toLocaleString()}`);
                return false;
            }
            
            // Show loading state
            const submitBtn = document.getElementById('submitBtn');
            submitBtn.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>Creating...';
            submitBtn.disabled = true;
            
            return true;
        });

        // Auto-load customer details if customer_id is pre-selected
        document.addEventListener('DOMContentLoaded', function() {
            if (document.getElementById('customerId').value) {
                loadCustomerDetails();
            }
        });

        // Auto-dismiss alerts
        setTimeout(() => {
            document.querySelectorAll('.alert').forEach(alert => {
                const bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            });
        }, 5000);
    </script>
</body>
</html>