<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Millenium Cash</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            background: #f0f2f5;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            padding: 20px;
        }
        
        .receipt-container {
            max-width: 800px;
            margin: 0 auto;
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
            overflow: hidden;
        }
        
        .receipt-header {
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            color: white;
            padding: 30px;
            text-align: center;
        }
        
        .company-logo {
            font-size: 48px;
            margin-bottom: 10px;
        }
        
        .company-name {
            font-size: 28px;
            font-weight: bold;
            letter-spacing: 2px;
        }
        
        .company-subtitle {
            font-size: 14px;
            opacity: 0.9;
            margin-top: 5px;
        }
        
        .receipt-title {
            background: #f8f9fa;
            padding: 15px;
            text-align: center;
            border-bottom: 2px solid #dee2e6;
        }
        
        .receipt-title h3 {
            margin: 0;
            color: #2a5298;
            font-weight: bold;
        }
        
        .receipt-body {
            padding: 30px;
        }
        
        .info-section {
            margin-bottom: 25px;
        }
        
        .section-title {
            font-size: 16px;
            font-weight: bold;
            color: #2a5298;
            border-bottom: 2px solid #2a5298;
            padding-bottom: 8px;
            margin-bottom: 15px;
        }
        
        .info-row {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px dashed #e9ecef;
        }
        
        .info-label {
            font-weight: 600;
            color: #495057;
            width: 40%;
        }
        
        .info-value {
            color: #212529;
            width: 60%;
            text-align: right;
            font-weight: 500;
        }
        
        .amount-box {
            background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
            padding: 20px;
            border-radius: 10px;
            text-align: center;
            margin: 20px 0;
        }
        
        .amount-label {
            font-size: 14px;
            color: #155724;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        
        .amount-value {
            font-size: 36px;
            font-weight: bold;
            color: #155724;
        }
        
        .status-badge {
            display: inline-block;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
        }
        
        .status-completed {
            background: #d4edda;
            color: #155724;
        }
        
        .signature-section {
            margin-top: 40px;
            padding-top: 20px;
            border-top: 1px solid #dee2e6;
        }
        
        .signature-line {
            margin-top: 30px;
        }
        
        .signature-item {
            text-align: center;
        }
        
        .signature-line-dash {
            border-bottom: 1px solid #000;
            width: 80%;
            margin: 0 auto 10px auto;
            padding-top: 20px;
        }
        
        .receipt-footer {
            background: #f8f9fa;
            padding: 20px;
            text-align: center;
            border-top: 1px solid #dee2e6;
        }
        
        .print-button {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 1000;
        }
        
        @media print {
            .print-button, .no-print {
                display: none !important;
            }
            body {
                background: white;
                padding: 0;
                margin: 0;
            }
            .receipt-container {
                box-shadow: none;
                margin: 0;
                border-radius: 0;
            }
        }
    </style>
</head>
<body>
    <div class="receipt-container">
        <!-- Receipt Header -->
        <div class="receipt-header">
            <div class="company-logo">
                <i class="bi bi-cash-coin"></i>
            </div>
            <div class="company-name">MILLENIUM CASH</div>
            <div class="company-subtitle">Pension Loan System</div>
        </div>

        <!-- Receipt Title -->
        <div class="receipt-title">
            <h3>COLLECTION POSTING RECEIPT</h3>
            <p class="mb-0 text-muted">Official Receipt</p>
        </div>

        <!-- Receipt Body -->
        <div class="receipt-body">
            <!-- Reference Number -->
            <div class="info-section">
                <div class="info-row">
                    <span class="info-label">Posting Reference:</span>
                    <span class="info-value"><strong><%= posting.posting_reference || 'N/A' %></strong></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Posting ID:</span>
                    <span class="info-value">#<%= posting.posting_id || 'N/A' %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Date & Time:</span>
                    <span class="info-value">
                        <%= posting.created_at ? new Date(posting.created_at).toLocaleString() : new Date().toLocaleString() %>
                    </span>
                </div>
                <div class="info-row">
                    <span class="info-label">Status:</span>
                    <span class="info-value">
                        <span class="status-badge status-completed">
                            <i class="bi bi-check-circle-fill"></i> COMPLETED
                        </span>
                    </span>
                </div>
            </div>

            <!-- Amount Box -->
            <div class="amount-box">
                <div class="amount-label">POSTING AMOUNT</div>
                <div class="amount-value">₱<%= posting.amount ? parseFloat(posting.amount).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) : '0.00' %></div>
                <div class="amount-label mt-2">PHILIPPINE PESO</div>
            </div>

            <!-- Posting Type -->
            <div class="info-section">
                <div class="section-title">
                    <i class="bi bi-info-circle me-2"></i>Posting Information
                </div>
                <div class="info-row">
                    <span class="info-label">Posting Type:</span>
                    <span class="info-value">
                        <% if (posting.posting_type === 'bank_deposit') { %>
                            <i class="bi bi-bank me-1"></i> BANK DEPOSIT
                        <% } else { %>
                            <i class="bi bi-cash-coin me-1"></i> CHANGE FUND
                        <% } %>
                    </span>
                </div>
            </div>

            <!-- Customer Information -->
            <div class="info-section">
                <div class="section-title">
                    <i class="bi bi-person me-2"></i>Customer Information
                </div>
                <div class="info-row">
                    <span class="info-label">Customer Name:</span>
                    <span class="info-value"><%= (posting.first_name || '') + ' ' + (posting.last_name || '') || 'N/A' %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Pension Number:</span>
                    <span class="info-value"><%= posting.pension_number || 'N/A' %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Withdrawal Amount:</span>
                    <span class="info-value">₱<%= posting.withdrawal_amount ? parseFloat(posting.withdrawal_amount).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) : '0.00' %></span>
                </div>
            </div>

            <!-- Bank Details (if bank deposit) -->
            <% if (posting.posting_type === 'bank_deposit') { %>
            <div class="info-section">
                <div class="section-title">
                    <i class="bi bi-bank me-2"></i>Bank Deposit Details
                </div>
                <div class="info-row">
                    <span class="info-label">Bank Name:</span>
                    <span class="info-value"><%= posting.bank_name || 'N/A' %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Account Number:</span>
                    <span class="info-value"><%= posting.account_number || 'N/A' %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Reference Number:</span>
                    <span class="info-value"><code><%= posting.reference_number || 'N/A' %></code></span>
                </div>
            </div>
            <% } %>

            <!-- Processed By -->
            <div class="info-section">
                <div class="section-title">
                    <i class="bi bi-person-check me-2"></i>Transaction Details
                </div>
                <div class="info-row">
                    <span class="info-label">Processed By:</span>
                    <span class="info-value"><%= posting.posted_by_name || 'System' %></span>
                </div>
                <% if (posting.notes) { %>
                <div class="info-row">
                    <span class="info-label">Notes:</span>
                    <span class="info-value"><%= posting.notes %></span>
                </div>
                <% } %>
            </div>

            <!-- Signature Section -->
            <div class="signature-section">
                <div class="row">
                    <div class="col-6 signature-item">
                        <div class="signature-line-dash"></div>
                        <small>Customer Signature</small>
                        <div><small class="text-muted">Date: ________________</small></div>
                    </div>
                    <div class="col-6 signature-item">
                        <div class="signature-line-dash"></div>
                        <small>Authorized Representative</small>
                        <div><small class="text-muted">Date: ________________</small></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Receipt Footer -->
        <div class="receipt-footer">
            <small>
                <i class="bi bi-envelope"></i> support@milleniumcash.com | 
                <i class="bi bi-telephone"></i> (02) 1234 5678
            </small>
            <br>
            <small class="text-muted">This is a computer-generated receipt. No signature required.</small>
            <br>
            <small class="text-muted mt-2 d-block">Thank you for your transaction!</small>
        </div>
    </div>

    <!-- Print Button -->
    <div class="print-button no-print">
        <button onclick="window.print()" class="btn btn-primary btn-lg" style="border-radius: 50px; padding: 12px 24px;">
            <i class="bi bi-printer me-2"></i>Print Receipt
        </button>
        <button onclick="window.close()" class="btn btn-secondary btn-lg ms-2" style="border-radius: 50px; padding: 12px 24px;">
            <i class="bi bi-x-circle me-2"></i>Close
        </button>
    </div>

    <script>
        // Auto-print option (uncomment if you want automatic printing)
        // setTimeout(function() {
        //     window.print();
        // }, 500);
        
        // Keyboard shortcut: Ctrl+P
        document.addEventListener('keydown', function(e) {
            if ((e.ctrlKey || e.metaKey) && e.key === 'p') {
                e.preventDefault();
                window.print();
            }
        });
        
        // Debug info - remove in production
        console.log('Receipt Data:', {
            posting_id: <%= posting.posting_id %>,
            posting_reference: '<%= posting.posting_reference %>',
            amount: '<%= posting.amount %>',
            type: '<%= posting.posting_type %>'
        });
    </script>
</body>
</html>