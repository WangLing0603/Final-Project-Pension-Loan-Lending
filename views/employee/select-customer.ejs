<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/dashboard">
                <i class="bi bi-cash-coin me-2"></i>Pension Loan System
            </a>
        </div>
    </nav>

    <div class="container my-4">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0"><i class="bi bi-person-plus me-2"></i>Select Customer for Loan</h4>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-4">Choose a customer to create a new loan application for:</p>
                        
                        <div class="list-group">
                            <% customers.forEach(customer => { %>
                            <a href="/employee/customer/<%= customer.user_id %>/create-loan" 
                               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1"><%= customer.full_name %></h6>
                                    <small class="text-muted">
                                        Pension #: <%= customer.pension_number %> | 
                                        Monthly: ₱<%= (customer.monthly_pension || 0).toLocaleString() %>
                                    </small>
                                </div>
                                <i class="bi bi-chevron-right text-muted"></i>
                            </a>
                            <% }); %>
                        </div>
                        
                        <div class="mt-4">
                            <a href="/dashboard" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>