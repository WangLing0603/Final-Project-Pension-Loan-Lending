<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Millenium Cash</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        .page-header {
            background: linear-gradient(135deg, #fd7e14 0%, #e55a00 100%);
            color: white;
            border-radius: 15px;
            padding: 25px;
        }
        .stat-card {
            border-radius: 12px;
            border: none;
            transition: transform 0.3s ease;
            cursor: pointer;
        }
        .stat-card:hover {
            transform: translateY(-3px);
        }
        .posting-card {
            border-left: 4px solid #fd7e14;
            border-radius: 10px;
            transition: all 0.3s ease;
        }
        .posting-card.bank_deposit { border-left-color: #007bff; }
        .posting-card.change_fund { border-left-color: #28a745; }
        .posting-card:hover {
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            transform: translateY(-2px);
        }
        .type-badge {
            font-size: 0.75rem;
            padding: 6px 12px;
            border-radius: 20px;
        }
        .fund-balance {
            background: linear-gradient(135deg, #28a745 0%, #1e7e34 100%);
            color: white;
            border-radius: 10px;
            padding: 20px;
        }
        .customer-avatar {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 16px;
        }
        .search-box {
            max-width: 300px;
        }
        .empty-state {
            padding: 3rem 1rem;
            text-align: center;
            color: #6c757d;
        }
        .empty-state i {
            font-size: 4rem;
            margin-bottom: 1rem;
            opacity: 0.5;
        }
        .table-hover tbody tr:hover {
            background: linear-gradient(135deg, #fff9f0 0%, #ffe8cc 100%);
            cursor: pointer;
        }
        .filter-active {
            background-color: #fd7e14 !important;
            color: white !important;
            border-color: #fd7e14 !important;
        }
        .btn-group .btn-outline-primary.filter-active {
            background-color: #0d6efd !important;
            border-color: #0d6efd !important;
        }
        .btn-group .btn-outline-info.filter-active {
            background-color: #0dcaf0 !important;
            color: white !important;
            border-color: #0dcaf0 !important;
        }
        .btn-group .btn-outline-success.filter-active {
            background-color: #28a745 !important;
            color: white !important;
            border-color: #28a745 !important;
        }
        .status-badge {
            font-size: 0.7rem;
            padding: 4px 8px;
            border-radius: 20px;
        }
        .action-buttons .btn {
            border-radius: 20px;
            padding: 5px 12px;
            font-size: 0.75rem;
        }
        .loading-spinner {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            z-index: 9999;
            display: none;
        }
        .export-btn {
            transition: all 0.3s ease;
        }
        .export-btn:hover {
            transform: scale(1.05);
        }
    </style>
</head>
<body class="bg-light">
    <!-- Loading Spinner -->
    <div class="loading-spinner" id="loadingSpinner">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/dashboard">
                <i class="bi bi-cash-coin me-2"></i>Millenium Cash
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <div class="navbar-nav ms-auto">
                    <a class="nav-link" href="/dashboard">Dashboard</a>
                    <a class="nav-link" href="/loans">Loan Applications</a>
                    <a class="nav-link" href="/employee/pension-withdrawals">Pension Withdrawals</a>
                    <a class="nav-link" href="/employee/create-withdrawal">Create Withdrawal</a>
                    <a class="nav-link active" href="/employee/collection-postings">Collection Postings</a>
                    <a class="nav-link" href="/employee/payments">Payment Posting</a>
                    <a class="nav-link" href="/profile">Profile</a>
                    <a class="nav-link" href="/logout">Logout</a>
                </div>
            </div>
        </div>
    </nav>

    <div class="container my-4">
        <!-- Page Header -->
        <div class="page-header mb-4">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h1 class="mb-2"><i class="bi bi-journal-check me-2"></i>Collection Postings</h1>
                    <p class="mb-0 opacity-75">Track and manage collection postings to bank or change fund</p>
                </div>
                <div class="col-md-4 text-end">
                    <div class="fund-balance">
                        <small class="d-block">Change Fund Balance</small>
                        <h3 class="mb-0">₱<%= (typeof changeFundBalance !== 'undefined' && changeFundBalance ? changeFundBalance : 0).toLocaleString() %></h3>
                    </div>
                </div>
            </div>
        </div>

        <!-- Alerts -->
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>
        
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i><%= success %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        <!-- Statistics Cards -->
        <div class="row mb-4">
            <div class="col-xl-3 col-md-6 mb-3">
                <div class="card stat-card bg-primary text-white shadow-sm" onclick="filterByType('all')">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-1 opacity-75">Total Postings</h6>
                                <h2 class="mb-0"><%= postings && postings.length ? postings.length : 0 %></h2>
                            </div>
                            <i class="bi bi-journal-bookmark-fill fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6 mb-3">
                <div class="card stat-card bg-info text-white shadow-sm" onclick="filterByType('bank_deposit')">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-1 opacity-75">Bank Deposits</h6>
                                <h2 class="mb-0">
                                    <%= postings && postings.length ? postings.filter(function(p) { return p.posting_type === 'bank_deposit'; }).length : 0 %>
                                </h2>
                            </div>
                            <i class="bi bi-bank fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6 mb-3">
                <div class="card stat-card bg-success text-white shadow-sm" onclick="filterByType('change_fund')">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-1 opacity-75">Change Fund</h6>
                                <h2 class="mb-0">
                                    <%= postings && postings.length ? postings.filter(function(p) { return p.posting_type === 'change_fund'; }).length : 0 %>
                                </h2>
                            </div>
                            <i class="bi bi-cash-coin fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6 mb-3">
                <div class="card stat-card bg-warning text-dark shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-1 opacity-75">Total Posted</h6>
                                <h2 class="mb-0">
                                    ₱<%= postings && postings.length ? postings.reduce(function(total, p) { 
                                        return total + parseFloat(p.amount || 0); 
                                    }, 0).toLocaleString() : 0 %>
                                </h2>
                            </div>
                            <i class="bi bi-calculator fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filters and Search -->
        <div class="card mb-4 shadow-sm">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-6 mb-3 mb-md-0">
                        <h6 class="mb-2"><i class="bi bi-funnel me-1"></i>Filter by Type:</h6>
                        <div class="btn-group flex-wrap" role="group">
                            <a href="/employee/collection-postings" class="btn btn-outline-primary <%= typeof typeFilter === 'undefined' || typeFilter === 'all' ? 'filter-active' : '' %>">
                                <i class="bi bi-grid-3x3-gap-fill me-1"></i>All Postings
                            </a>
                            <a href="/employee/collection-postings?type=bank_deposit" class="btn btn-outline-info <%= typeFilter === 'bank_deposit' ? 'filter-active' : '' %>">
                                <i class="bi bi-bank me-1"></i>Bank Deposits
                            </a>
                            <a href="/employee/collection-postings?type=change_fund" class="btn btn-outline-success <%= typeFilter === 'change_fund' ? 'filter-active' : '' %>">
                                <i class="bi bi-cash-coin me-1"></i>Change Fund
                            </a>
                        </div>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <div class="d-flex gap-2 justify-content-end">
                            <div class="input-group search-box">
                                <span class="input-group-text bg-white border-end-0">
                                    <i class="bi bi-search text-muted"></i>
                                </span>
                                <input type="text" class="form-control border-start-0" placeholder="Search by customer, bank, reference..." id="searchPostings">
                            </div>
                            <button class="btn btn-outline-secondary export-btn" onclick="exportToCSV()" title="Export to CSV">
                                <i class="bi bi-download"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Collection Postings Table -->
        <div class="card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center border-bottom">
                <h5 class="mb-0">
                    <i class="bi bi-journal-text me-2 text-warning"></i>
                    Collection Posting Records
                    <span class="badge bg-primary ms-2"><%= postings && postings.length ? postings.length : 0 %></span>
                </h5>
                <div class="text-muted small">
                    <i class="bi bi-clock me-1"></i>
                    <span id="lastUpdated"><%= new Date().toLocaleTimeString() %></span>
                </div>
            </div>
            <div class="card-body p-0">
                <% if (postings && postings.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover mb-0" id="postingsTable">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 80px">ID</th>
                                    <th>Customer</th>
                                    <th style="width: 130px">Withdrawal Amount</th>
                                    <th style="width: 120px">Posting Amount</th>
                                    <th style="width: 120px">Posting Type</th>
                                    <th>Bank Details</th>
                                    <th style="width: 120px">Reference</th>
                                    <th style="width: 120px">Date</th>
                                    <th style="width: 120px">Posted By</th>
                                    <th style="width: 100px">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% postings.forEach(function(posting) { 
                                    const fullName = ((posting.first_name || '') + ' ' + (posting.last_name || '')).trim();
                                    const displayName = fullName || 'Unknown Customer';
                                    const initials = ((posting.first_name ? posting.first_name[0] : '') + (posting.last_name ? posting.last_name[0] : '')).toUpperCase() || '?';
                                    const postingDate = posting.posting_date || posting.created_at;
                                    const status = posting.status || 'completed';
                                %>
                                <tr class="posting-row" onclick="viewPostingDetails(<%= posting.posting_id %>)" style="cursor: pointer;">
                                    <td class="align-middle">
                                        <span class="fw-bold text-primary">#<%= posting.posting_id %></span>
                                        <br>
                                        <small class="text-muted"><%= posting.posting_reference || 'N/A' %></small>
                                    </td>
                                    <td class="align-middle">
                                        <div class="d-flex align-items-center">
                                            <div class="customer-avatar me-3 flex-shrink-0">
                                                <%= initials %>
                                            </div>
                                            <div>
                                                <div class="fw-bold"><%= displayName %></div>
                                                <small class="text-muted">
                                                    <i class="bi bi-person-badge me-1"></i>
                                                    <%= posting.pension_number || 'N/A' %>
                                                </small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="align-middle">
                                        <span class="text-muted">₱<%= parseFloat(posting.withdrawal_amount || 0).toLocaleString() %></span>
                                    </td>
                                    <td class="align-middle">
                                        <strong class="text-success">₱<%= parseFloat(posting.amount || 0).toLocaleString() %></strong>
                                    </td>
                                    <td class="align-middle">
                                        <span class="badge type-badge bg-<%= posting.posting_type === 'bank_deposit' ? 'info' : 'success' %>">
                                            <i class="bi bi-<%= posting.posting_type === 'bank_deposit' ? 'bank' : 'cash-coin' %> me-1"></i>
                                            <%= posting.posting_type === 'bank_deposit' ? 'BANK DEPOSIT' : 'CHANGE FUND' %>
                                        </span>
                                        <% if (status !== 'completed') { %>
                                            <span class="badge bg-secondary status-badge ms-1"><%= status %></span>
                                        <% } %>
                                    </td>
                                    <td class="align-middle">
                                        <% if (posting.posting_type === 'bank_deposit') { %>
                                            <div class="small">
                                                <div class="fw-bold"><%= posting.bank_name || 'N/A' %></div>
                                                <div class="text-muted">Acct: <%= posting.account_number || 'N/A' %></div>
                                            </div>
                                        <% } else { %>
                                            <span class="text-muted">
                                                <i class="bi bi-cash-stack me-1"></i>Change Fund
                                            </span>
                                        <% } %>
                                    </td>
                                    <td class="align-middle">
                                        <code class="small"><%= posting.reference_number || 'N/A' %></code>
                                    </td>
                                    <td class="align-middle">
                                        <div class="small">
                                            <div class="fw-bold">
                                                <%= postingDate ? new Date(postingDate).toLocaleDateString() : 'N/A' %>
                                            </div>
                                            <small class="text-muted">
                                                Created: <%= posting.created_at ? new Date(posting.created_at).toLocaleDateString() : 'N/A' %>
                                            </small>
                                        </div>
                                    </td>
                                    <td class="align-middle">
                                        <small class="text-muted">
                                            <i class="bi bi-person-circle me-1"></i>
                                            <%= posting.posted_by_name || 'System' %>
                                        </small>
                                    </td>
                                    <td class="align-middle">
                                        <div class="action-buttons d-flex gap-1" onclick="event.stopPropagation()">
                                            <a href="/employee/posting/<%= posting.posting_id %>" 
                                               class="btn btn-outline-primary btn-sm"
                                               data-bs-toggle="tooltip" title="View Details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a href="/employee/posting/<%= posting.posting_id %>/receipt" 
                                               class="btn btn-outline-info btn-sm"
                                               data-bs-toggle="tooltip" title="View Receipt"
                                               target="_blank">
                                                <i class="bi bi-receipt"></i>
                                            </a>
                                            <% if (status === 'completed') { %>
                                            <button class="btn btn-outline-secondary btn-sm" 
                                                    onclick="printPostingReceipt(<%= posting.posting_id %>)"
                                                    data-bs-toggle="tooltip" title="Print Receipt">
                                                <i class="bi bi-printer"></i>
                                            </button>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>

                    <!-- Summary Section -->
                    <div class="row mt-4 p-3 border-top">
                        <div class="col-md-12">
                            <div class="card bg-light border-0">
                                <div class="card-body">
                                    <h6 class="card-title mb-3"><i class="bi bi-pie-chart me-2"></i>Posting Summary</h6>
                                    <div class="row">
                                        <div class="col-md-4">
                                            <div class="d-flex justify-content-between mb-2">
                                                <span>Total Bank Deposits:</span>
                                                <strong class="text-info">
                                                    ₱<%= postings && postings.length ? postings.filter(function(p) { return p.posting_type === 'bank_deposit'; }).reduce(function(total, p) { return total + parseFloat(p.amount || 0); }, 0).toLocaleString() : 0 %>
                                                </strong>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="d-flex justify-content-between mb-2">
                                                <span>Total Change Fund:</span>
                                                <strong class="text-success">
                                                    ₱<%= postings && postings.length ? postings.filter(function(p) { return p.posting_type === 'change_fund'; }).reduce(function(total, p) { return total + parseFloat(p.amount || 0); }, 0).toLocaleString() : 0 %>
                                                </strong>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="d-flex justify-content-between mb-2">
                                                <span>Number of Transactions:</span>
                                                <strong><%= postings ? postings.length : 0 %></strong>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                <% } else { %>
                    <div class="empty-state">
                        <i class="bi bi-journal-x"></i>
                        <h4 class="text-muted mt-3">No Collection Postings Found</h4>
                        <p class="text-muted mb-4">
                            <% if (typeof typeFilter !== 'undefined' && typeFilter !== 'all' && typeFilter) { %>
                                No <strong><%= typeFilter.replace('_', ' ') %></strong> postings found in the system.
                            <% } else { %>
                                No collection posting records found in the system.
                            <% } %>
                        </p>
                        <a href="/employee/pension-withdrawals" class="btn btn-primary btn-lg">
                            <i class="bi bi-arrow-left me-2"></i>Go to Withdrawals
                        </a>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Quick Actions Footer -->
        <div class="row mt-4">
            <div class="col-12">
                <div class="card bg-light border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div>
                                <i class="bi bi-info-circle-fill text-info me-2"></i>
                                <small class="text-muted">
                                    Collection postings are created from completed pension withdrawals.
                                    <a href="/employee/create-withdrawal" class="text-decoration-none">Create new withdrawal →</a>
                                </small>
                            </div>
                            <div>
                                <button class="btn btn-sm btn-outline-secondary" onclick="refreshPage()">
                                    <i class="bi bi-arrow-repeat me-1"></i>Refresh
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- View Posting Modal -->
    <div class="modal fade" id="viewPostingModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-journal-text me-2"></i>Posting Details
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="postingDetailsContent">
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary" onclick="printPostingReceiptFromModal()">
                        <i class="bi bi-printer"></i> Print Receipt
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let currentPostingId = null;

        // Auto-dismiss alerts after 5 seconds
        setTimeout(function() {
            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(function(alert) {
                const bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            });
        }, 5000);

        // Filter by type
        function filterByType(type) {
            if (type === 'all') {
                window.location.href = '/employee/collection-postings';
            } else {
                window.location.href = `/employee/collection-postings?type=${type}`;
            }
        }

        // Search functionality
        const searchInput = document.getElementById('searchPostings');
        if (searchInput) {
            searchInput.addEventListener('input', function(e) {
                const searchTerm = e.target.value.toLowerCase().trim();
                const rows = document.querySelectorAll('.posting-row');
                let visibleCount = 0;
                
                rows.forEach(function(row) {
                    const text = row.textContent.toLowerCase();
                    if (searchTerm === '' || text.includes(searchTerm)) {
                        row.style.display = '';
                        visibleCount++;
                    } else {
                        row.style.display = 'none';
                    }
                });
                
                // Show/hide empty message if needed
                const tableBody = document.querySelector('#postingsTable tbody');
                const emptyMessage = document.querySelector('.search-empty-message');
                
                if (visibleCount === 0 && searchTerm !== '') {
                    if (!emptyMessage && tableBody) {
                        const colspan = document.querySelector('#postingsTable thead th') ? 
                            document.querySelectorAll('#postingsTable thead th').length : 10;
                        const msg = document.createElement('tr');
                        msg.className = 'search-empty-message';
                        msg.innerHTML = '<td colspan="' + colspan + '" class="text-center py-5 text-muted">' +
                            '<i class="bi bi-search fs-1 d-block mb-2"></i>' +
                            'No postings matching "' + searchTerm + '"</td>';
                        tableBody.appendChild(msg);
                    }
                } else if (emptyMessage) {
                    emptyMessage.remove();
                }
            });
        }

        // View posting details
        function viewPostingDetails(postingId) {
            currentPostingId = postingId;
            const modal = new bootstrap.Modal(document.getElementById('viewPostingModal'));
            
            fetch(`/api/posting/${postingId}`)
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        const posting = data.posting;
                        document.getElementById('postingDetailsContent').innerHTML = `
                            <div class="row">
                                <div class="col-md-6">
                                    <h6>Posting Information</h6>
                                    <table class="table table-sm table-bordered">
                                        <tr><th>Posting ID:</th><td>#${posting.posting_id}</td></tr>
                                        <tr><th>Posting Reference:</th><td>${posting.posting_reference || 'N/A'}</td></tr>
                                        <tr><th>Posting Type:</th><td>
                                            <span class="badge bg-${posting.posting_type === 'bank_deposit' ? 'info' : 'success'}">
                                                ${posting.posting_type === 'bank_deposit' ? 'BANK DEPOSIT' : 'CHANGE FUND'}
                                            </span>
                                        </td></tr>
                                        <tr><th>Amount:</th><td class="text-success fw-bold">₱${parseFloat(posting.amount).toLocaleString()}</td></tr>
                                        <tr><th>Status:</th><td><span class="badge bg-${posting.status === 'completed' ? 'success' : 'warning'}">${posting.status}</span></td></tr>
                                        <tr><th>Created At:</th><td>${new Date(posting.created_at).toLocaleString()}</td></tr>
                                    </table>
                                </div>
                                <div class="col-md-6">
                                    <h6>Customer Information</h6>
                                    <table class="table table-sm table-bordered">
                                        <tr><th>Name:</th><td>${posting.first_name || ''} ${posting.last_name || ''}</td></tr>
                                        <tr><th>Pension Number:</th><td>${posting.pension_number || 'N/A'}</td></tr>
                                        <tr><th>Withdrawal Amount:</th><td>₱${parseFloat(posting.withdrawal_amount || 0).toLocaleString()}</td></tr>
                                    </table>
                                </div>
                            </div>
                            ${posting.posting_type === 'bank_deposit' ? `
                            <div class="row mt-3">
                                <div class="col-12">
                                    <h6>Bank Details</h6>
                                    <table class="table table-sm table-bordered">
                                        <tr><th>Bank Name:</th><td>${posting.bank_name || 'N/A'}</td></tr>
                                        <tr><th>Account Number:</th><td>${posting.account_number || 'N/A'}</td></tr>
                                        <tr><th>Reference Number:</th><td><code>${posting.reference_number || 'N/A'}</code></td></tr>
                                    </table>
                                </div>
                            </div>
                            ` : ''}
                            <div class="row mt-3">
                                <div class="col-12">
                                    <h6>Posting Information</h6>
                                    <table class="table table-sm table-bordered">
                                        <tr><th>Posted By:</th><td>${posting.posted_by_name || 'System'}</td></tr>
                                        <tr><th>Posting Date:</th><td>${posting.posting_date ? new Date(posting.posting_date).toLocaleString() : 'N/A'}</td></tr>
                                    </table>
                                </div>
                            </div>
                        `;
                        modal.show();
                    } else {
                        alert('Error loading posting details: ' + (data.message || 'Unknown error'));
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Error loading posting details');
                });
        }

        // Print posting receipt
        function printPostingReceipt(postingId) {
            const printWindow = window.open(`/employee/posting/${postingId}/receipt`, '_blank');
            if (printWindow) {
                printWindow.focus();
            } else {
                alert('Please allow pop-ups to print receipts');
            }
        }

        function printPostingReceiptFromModal() {
            if (currentPostingId) {
                printPostingReceipt(currentPostingId);
            }
        }

        // Export to CSV
        function exportToCSV() {
            const type = '<%= typeFilter || "all" %>';
            window.location.href = `/api/export-postings?type=${type}`;
        }

        // Refresh page
        function refreshPage() {
            window.location.reload();
        }

        // Update last updated time
        function updateLastUpdated() {
            const lastUpdatedSpan = document.getElementById('lastUpdated');
            if (lastUpdatedSpan) {
                lastUpdatedSpan.textContent = new Date().toLocaleTimeString();
            }
        }
        
        // Auto-refresh every 5 minutes (optional)
        setInterval(function() {
            if (!document.querySelector('.modal.show')) {
                updateLastUpdated();
            }
        }, 300000);

        // Initialize tooltips
        document.addEventListener('DOMContentLoaded', function() {
            const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.forEach(function(tooltipTriggerEl) {
                new bootstrap.Tooltip(tooltipTriggerEl);
            });
        });
    </script>
</body>
</html>