<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/dashboard">
                <i class="bi bi-cash-coin"></i> Pension Loan System
            </a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/dashboard">Dashboard</a>
                <a class="nav-link" href="/employee/register-customer">Register Customer</a>
                <a class="nav-link" href="/loans">Loans</a>
                <a class="nav-link" href="/profile">Profile</a>
                <a class="nav-link" href="/logout">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container my-4">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">
                            <i class="bi bi-files"></i> Customer Documents - <%= customer.full_name %>
                        </h4>
                        <a href="/employee/customer/<%= customer.user_id %>" class="btn btn-light btn-sm">
                            <i class="bi bi-arrow-left"></i> Back to Profile
                        </a>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <div class="card">
                                    <div class="card-body">
                                        <h6>Customer Information</h6>
                                        <p class="mb-1"><strong>Name:</strong> <%= customer.full_name %></p>
                                        <p class="mb-1"><strong>Pension No:</strong> <%= customer.pension_number %></p>
                                        <p class="mb-1"><strong>System:</strong> <%= customer.pension_system %></p>
                                        <p class="mb-0"><strong>Monthly Pension:</strong> ₱<%= customer.monthly_pension %></p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-8">
                                <div class="table-responsive">
                                    <table class="table table-striped">
                                        <thead>
                                            <tr>
                                                <th>Document Type</th>
                                                <th>File Name</th>
                                                <th>Uploaded</th>
                                                <th>Status</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% documents.forEach(doc => { %>
                                                <tr>
                                                    <td>
                                                        <span class="badge bg-info">
                                                            <%= doc.document_type.replace('_', ' ').toUpperCase() %>
                                                        </span>
                                                    </td>
                                                    <td><%= doc.file_name %></td>
                                                    <td><%= new Date(doc.uploaded_at).toLocaleDateString() %></td>
                                                    <td>
                                                        <span class="badge 
                                                            <%= doc.verification_status === 'verified' ? 'bg-success' : 
                                                                doc.verification_status === 'rejected' ? 'bg-danger' : 'bg-warning' %>">
                                                            <%= doc.verification_status.toUpperCase() %>
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <a href="/<%= doc.file_path %>" target="_blank" class="btn btn-sm btn-outline-primary">
                                                            <i class="bi bi-eye"></i> View
                                                        </a>
                                                        <a href="/<%= doc.file_path %>" download class="btn btn-sm btn-outline-secondary">
                                                            <i class="bi bi-download"></i> Download
                                                        </a>
                                                    </td>
                                                </tr>
                                            <% }); %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>