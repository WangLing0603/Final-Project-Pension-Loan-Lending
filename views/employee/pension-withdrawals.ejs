<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Millenium Cash</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        .page-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-radius: 15px;
            padding: 25px;
        }
        .stat-card {
            border-radius: 12px;
            border: none;
            transition: transform 0.3s ease;
            cursor: pointer;
        }
        .stat-card:hover {
            transform: translateY(-3px);
        }
        .withdrawal-card {
            border-left: 4px solid;
            border-radius: 10px;
            transition: all 0.3s ease;
            margin-bottom: 15px;
        }
        .withdrawal-card.pending { border-left-color: #ffc107; }
        .withdrawal-card.completed { border-left-color: #28a745; }
        .withdrawal-card.processing { border-left-color: #17a2b8; }
        .withdrawal-card.cancelled { border-left-color: #dc3545; }
        .status-badge {
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }
        .action-buttons .btn {
            border-radius: 20px;
            padding: 5px 12px;
            font-size: 12px;
        }
        .empty-state {
            padding: 3rem 1rem;
            text-align: center;
            color: #6c757d;
        }
        .empty-state i {
            font-size: 4rem;
            margin-bottom: 1rem;
            opacity: 0.5;
        }
        .filter-active {
            background-color: #fd7e14 !important;
            color: white !important;
            border-color: #fd7e14 !important;
        }
    </style>
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/dashboard">
                <i class="bi bi-cash-coin me-2"></i>Millenium Cash
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/dashboard">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" href="/loans">Loan Applications</a></li>
                    <li class="nav-item"><a class="nav-link" href="/employee/register-customer">Register Customer</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/employee/pension-withdrawals">Pension Withdrawals</a></li>
                    <li class="nav-item"><a class="nav-link" href="/employee/create-withdrawal">Create Withdrawal</a></li>
                    <li class="nav-item"><a class="nav-link" href="/employee/collection-postings">Collection Postings</a></li>
                    <li class="nav-item"><a class="nav-link" href="/employee/payments">Payment Posting</a></li>
                    <li class="nav-item"><a class="nav-link" href="/profile">Profile</a></li>
                    <li class="nav-item"><a class="nav-link" href="/logout">Logout</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container my-4">
        <!-- Page Header -->
        <div class="page-header mb-4">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h1 class="mb-2"><i class="bi bi-cash-withdrawal me-2"></i>Pension Withdrawals</h1>
                    <p class="mb-0 opacity-75">Manage and process pension withdrawal requests</p>
                </div>
                <div class="col-md-4 text-end">
                    <a href="/employee/create-withdrawal" class="btn btn-light btn-lg">
                        <i class="bi bi-plus-circle me-2"></i>New Withdrawal
                    </a>
                </div>
            </div>
        </div>

        <!-- Alerts -->
        <% if (error) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>
        
        <% if (success) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i><%= success %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        <!-- Statistics Cards -->
        <div class="row mb-4">
            <div class="col-xl-3 col-md-6 mb-3">
                <div class="card stat-card bg-primary text-white shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-1 opacity-75">Total Withdrawals</h6>
                                <h2 class="mb-0"><%= stats ? stats.total_withdrawals || 0 : 0 %></h2>
                            </div>
                            <i class="bi bi-cash-stack fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6 mb-3">
                <div class="card stat-card bg-success text-white shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-1 opacity-75">Completed</h6>
                                <h2 class="mb-0"><%= stats ? stats.completed_count || 0 : 0 %></h2>
                            </div>
                            <i class="bi bi-check-circle fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6 mb-3">
                <div class="card stat-card bg-warning text-dark shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-1 opacity-75">Pending</h6>
                                <h2 class="mb-0"><%= stats ? stats.pending_count || 0 : 0 %></h2>
                            </div>
                            <i class="bi bi-hourglass-split fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6 mb-3">
                <div class="card stat-card bg-info text-white shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-1 opacity-75">Total Amount</h6>
                                <h2 class="mb-0">₱<%= stats ? (stats.total_amount || 0).toLocaleString() : 0 %></h2>
                            </div>
                            <i class="bi bi-currency-dollar fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filters -->
        <div class="card mb-4 shadow-sm">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-6 mb-3 mb-md-0">
                        <h6 class="mb-2">Filter by Status:</h6>
                        <div class="btn-group" role="group">
                            <a href="/employee/pension-withdrawals" class="btn btn-outline-primary <%= currentFilter === 'all' ? 'filter-active' : '' %>">All</a>
                            <a href="/employee/pension-withdrawals?status=pending" class="btn btn-outline-warning <%= currentFilter === 'pending' ? 'filter-active' : '' %>">Pending</a>
                            <a href="/employee/pension-withdrawals?status=processing" class="btn btn-outline-info <%= currentFilter === 'processing' ? 'filter-active' : '' %>">Processing</a>
                            <a href="/employee/pension-withdrawals?status=completed" class="btn btn-outline-success <%= currentFilter === 'completed' ? 'filter-active' : '' %>">Completed</a>
                            <a href="/employee/pension-withdrawals?status=cancelled" class="btn btn-outline-danger <%= currentFilter === 'cancelled' ? 'filter-active' : '' %>">Cancelled</a>
                        </div>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <div class="input-group">
                            <input type="text" class="form-control" id="searchInput" placeholder="Search by customer name or pension number...">
                            <button class="btn btn-primary" onclick="searchWithdrawals()">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Withdrawals List -->
        <div class="card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="bi bi-list-ul me-2"></i>
                    Withdrawal Records
                </h5>
                <span class="badge bg-primary"><%= withdrawals ? withdrawals.length : 0 %> Records</span>
            </div>
            <div class="card-body">
                <% if (withdrawals && withdrawals.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>ID</th>
                                    <th>Customer</th>
                                    <th>Amount</th>
                                    <th>Method</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                    <th>Processed By</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% withdrawals.forEach(withdrawal => { %>
                                <tr>
                                    <td>#<%= withdrawal.withdrawal_id %></td>
                                    <td>
                                        <strong><%= withdrawal.first_name %> <%= withdrawal.last_name %></strong><br>
                                        <small class="text-muted"><%= withdrawal.pension_number %></small>
                                    </td>
                                    <td class="text-success fw-bold">₱<%= parseFloat(withdrawal.withdrawal_amount).toLocaleString() %></td>
                                    <td class="text-capitalize"><%= withdrawal.withdrawal_method ? withdrawal.withdrawal_method.replace('_', ' ') : 'N/A' %></td>
                                    <td><%= withdrawal.withdrawal_date ? new Date(withdrawal.withdrawal_date).toLocaleDateString() : 'N/A' %></td>
                                    <td>
                                        <span class="status-badge bg-<%= 
                                            withdrawal.status === 'completed' ? 'success' : 
                                            withdrawal.status === 'pending' ? 'warning' : 
                                            withdrawal.status === 'processing' ? 'info' : 'danger' 
                                        %> text-white">
                                            <%= withdrawal.status ? withdrawal.status.toUpperCase() : 'PENDING' %>
                                        </span>
                                    </td>
                                    <td><%= withdrawal.processed_by_name || 'System' %></td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a href="/employee/withdrawal/<%= withdrawal.withdrawal_id %>" 
                                               class="btn btn-outline-primary" title="View Details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            
                                            <% if (withdrawal.status === 'pending') { %>
                                                <button class="btn btn-outline-success" 
                                                        onclick="updateStatus(<%= withdrawal.withdrawal_id %>, 'processing')"
                                                        title="Start Processing">
                                                    <i class="bi bi-play-circle"></i>
                                                </button>
                                                <button class="btn btn-outline-info" 
                                                        onclick="updateStatus(<%= withdrawal.withdrawal_id %>, 'completed')"
                                                        title="Mark as Completed">
                                                    <i class="bi bi-check-circle"></i>
                                                </button>
                                            <% } %>
                                            
                                            <% if (withdrawal.status === 'processing') { %>
                                                <button class="btn btn-outline-success" 
                                                        onclick="updateStatus(<%= withdrawal.withdrawal_id %>, 'completed')"
                                                        title="Mark as Completed">
                                                    <i class="bi bi-check-circle"></i>
                                                </button>
                                            <% } %>
                                            
                                            <% if (withdrawal.status === 'completed' && withdrawal.posting_status !== 'posted') { %>
                                                <a href="/employee/create-posting?withdrawal_id=<%= withdrawal.withdrawal_id %>" 
                                                   class="btn btn-outline-info" title="Create Collection Posting">
                                                    <i class="bi bi-journal-plus"></i>
                                                </a>
                                            <% } %>
                                            
                                            <% if (withdrawal.status === 'completed' && withdrawal.posting_status === 'posted') { %>
                                                <a href="/employee/collection-postings" 
                                                   class="btn btn-outline-secondary" title="View Posting">
                                                    <i class="bi bi-journal-check"></i>
                                                </a>
                                            <% } %>
                                            
                                            <% if (withdrawal.status !== 'completed' && withdrawal.status !== 'cancelled') { %>
                                                <button class="btn btn-outline-danger" 
                                                        onclick="cancelWithdrawal(<%= withdrawal.withdrawal_id %>)"
                                                        title="Cancel Withdrawal">
                                                    <i class="bi bi-x-circle"></i>
                                                </button>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="empty-state">
                        <i class="bi bi-cash-stack"></i>
                        <h4 class="mt-3">No Withdrawals Found</h4>
                        <p class="text-muted">
                            <% if (currentFilter !== 'all') { %>
                                No <strong><%= currentFilter %></strong> withdrawals found.
                            <% } else { %>
                                No pension withdrawal records found in the system.
                            <% } %>
                        </p>
                        <a href="/employee/create-withdrawal" class="btn btn-primary">
                            <i class="bi bi-plus-circle me-2"></i>Create First Withdrawal
                        </a>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Update Status Modal -->
    <div class="modal fade" id="statusModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Update Withdrawal Status</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p id="statusMessage"></p>
                    <input type="hidden" id="statusWithdrawalId">
                    <input type="hidden" id="newStatus">
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" onclick="confirmStatusUpdate()">Confirm</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Search functionality
        function searchWithdrawals() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            const rows = document.querySelectorAll('tbody tr');
            
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                if (text.includes(searchTerm)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }

        // Update status
        function updateStatus(withdrawalId, status) {
            let message = '';
            if (status === 'processing') {
                message = 'Start processing this withdrawal?';
            } else if (status === 'completed') {
                message = 'Mark this withdrawal as completed? This will allow you to create a collection posting.';
            }
            
            document.getElementById('statusMessage').innerHTML = message;
            document.getElementById('statusWithdrawalId').value = withdrawalId;
            document.getElementById('newStatus').value = status;
            new bootstrap.Modal(document.getElementById('statusModal')).show();
        }

        // Confirm status update
        function confirmStatusUpdate() {
            const withdrawalId = document.getElementById('statusWithdrawalId').value;
            const status = document.getElementById('newStatus').value;
            
            fetch(`/employee/withdrawal/${withdrawalId}/status`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status: status })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Error updating withdrawal status');
            });
        }

        // Cancel withdrawal
        function cancelWithdrawal(withdrawalId) {
            const reason = prompt('Please provide a reason for cancellation:');
            if (reason) {
                fetch(`/employee/withdrawal/${withdrawalId}/status`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status: 'cancelled', reason: reason })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert('Error: ' + data.message);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Error cancelling withdrawal');
                });
            }
        }

        // Enter key search
        document.getElementById('searchInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                searchWithdrawals();
            }
        });

        // Auto-dismiss alerts
        setTimeout(() => {
            document.querySelectorAll('.alert').forEach(alert => {
                const bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            });
        }, 5000);
    </script>
</body>
</html>