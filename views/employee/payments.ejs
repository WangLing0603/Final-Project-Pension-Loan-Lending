<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Millenium Cash</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        .payment-card { 
            border-left: 4px solid #28a745; 
            border-radius: 8px; 
            transition: transform 0.2s;
        }
        .payment-card:hover { transform: translateY(-2px); }
        .payment-card.pending { border-left-color: #ffc107; }
        .payment-card.partial { border-left-color: #17a2b8; }
        .payment-card.overdue { border-left-color: #dc3545; }
        .payment-card.paid { border-left-color: #28a745; }
        .stat-card { 
            border-radius: 10px; 
            transition: transform 0.2s;
            cursor: pointer;
        }
        .stat-card:hover { transform: translateY(-3px); }
        .filter-active { font-weight: bold; }
        .receipt-modal { max-width: 500px; }
        .installment-item {
            cursor: pointer;
            transition: all 0.2s ease;
        }
        .installment-item:hover {
            background: #f8f9fa;
            transform: translateX(5px);
        }
        .installment-item.selected {
            background: #e3f2fd;
            border-left: 3px solid #007bff;
        }
        @media print {
            .no-print { display: none; }
            .receipt-container { margin: 0; padding: 0; }
        }
        .btn-group .btn.active {
            background-color: #0d6efd !important;
            color: white !important;
        }
        .quick-action-btn {
            border-radius: 10px;
            padding: 12px 24px;
            font-weight: 600;
        }
    </style>
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/dashboard">
                <i class="bi bi-cash-coin me-2"></i>Millenium Cash
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/dashboard">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" href="/loans">Loan Applications</a></li>
                    <li class="nav-item"><a class="nav-link" href="/employee/register-customer">Register Customer</a></li>
                    <li class="nav-item"><a class="nav-link" href="/employee/pension-withdrawals">Pension Withdrawals</a></li>
                    <li class="nav-item"><a class="nav-link" href="/employee/collection-postings">Collection Postings</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/employee/payments">Payment Posting</a></li>
                    <li class="nav-item"><a class="nav-link" href="/employee/calculator">Loan Calculator</a></li>
                    <li class="nav-item"><a class="nav-link" href="/profile">Profile</a></li>
                    <li class="nav-item"><a class="nav-link" href="/logout">Logout</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container my-4">
        <!-- Header with Post Payment Button -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="mb-1"><%= title %></h2>
                <p class="text-muted mb-0">Post and manage loan payments, generate receipts, and track collections</p>
            </div>
            <div class="d-flex gap-2">
                <!-- Post New Payment Button -->
                <button class="btn btn-success quick-action-btn" onclick="showPostPaymentModal()">
                    <i class="bi bi-plus-circle me-2"></i>Post New Payment
                </button>
                <a href="/loans" class="btn btn-primary quick-action-btn">
                    <i class="bi bi-search me-2"></i>Find Loan
                </a>
            </div>
        </div>

        <!-- Statistics Cards -->
        <div class="row mb-4">
            <div class="col-xl-2 col-md-4 mb-3">
                <div class="card stat-card bg-primary text-white" onclick="filterByStatus('all')">
                    <div class="card-body text-center">
                        <h4 class="mb-0"><%= stats.total_payments || 0 %></h4>
                        <small>Total Payments</small>
                        <i class="bi bi-arrow-right-circle ms-2"></i>
                    </div>
                </div>
            </div>
            <div class="col-xl-2 col-md-4 mb-3">
                <div class="card stat-card bg-success text-white" onclick="filterByStatus('paid')">
                    <div class="card-body text-center">
                        <h4 class="mb-0">₱<%= (stats.total_collected || 0).toLocaleString() %></h4>
                        <small>Amount Collected</small>
                    </div>
                </div>
            </div>
            <div class="col-xl-2 col-md-4 mb-3">
                <div class="card stat-card bg-warning text-dark" onclick="filterByStatus('pending')">
                    <div class="card-body text-center">
                        <h4 class="mb-0"><%= stats.pending_count || 0 %></h4>
                        <small>Pending</small>
                    </div>
                </div>
            </div>
            <div class="col-xl-2 col-md-4 mb-3">
                <div class="card stat-card bg-danger text-white" onclick="filterByStatus('overdue')">
                    <div class="card-body text-center">
                        <h4 class="mb-0"><%= stats.overdue_count || 0 %></h4>
                        <small>Overdue</small>
                    </div>
                </div>
            </div>
            <div class="col-xl-2 col-md-4 mb-3">
                <div class="card stat-card bg-info text-white" onclick="filterByStatus('partial')">
                    <div class="card-body text-center">
                        <h4 class="mb-0"><%= stats.partial_count || 0 %></h4>
                        <small>Partial Payments</small>
                    </div>
                </div>
            </div>
            <div class="col-xl-2 col-md-4 mb-3">
                <div class="card stat-card bg-secondary text-white">
                    <div class="card-body text-center">
                        <h4 class="mb-0"><%= stats.today_payments || 0 %></h4>
                        <small>Today's Payments</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Alert Messages -->
        <% if (success) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            <%= success %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% } %>
        
        <% if (error) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% } %>

        <!-- Quick Post Payment Section -->
        <div class="card mb-4">
            <div class="card-header bg-white">
                <h5 class="mb-0">
                    <i class="bi bi-plus-circle me-2 text-primary"></i>
                    Quick Post Payment
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-8">
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-upc-scan"></i></span>
                            <input type="text" class="form-control" id="loanSearchInput" 
                                   placeholder="Enter Loan ID or Customer Name/Pension Number">
                            <button class="btn btn-primary" type="button" onclick="searchLoan()">
                                <i class="bi bi-search"></i> Find Loan
                            </button>
                        </div>
                        <div id="loanSearchResults" class="mt-3" style="display: none;"></div>
                    </div>
                    <div class="col-md-4">
                        <div class="alert alert-info mb-0">
                            <i class="bi bi-info-circle-fill"></i>
                            <small>Enter Loan ID to quickly post a payment</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filters -->
        <div class="card mb-4">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-4">
                        <h6 class="mb-2">Filter by Status:</h6>
                        <div class="btn-group" role="group">
                            <a href="/employee/payments?status=all&date=<%= dateFilter %>" 
                               class="btn btn-outline-primary <%= currentFilter === 'all' ? 'active' : '' %>">All</a>
                            <a href="/employee/payments?status=paid&date=<%= dateFilter %>" 
                               class="btn btn-outline-success <%= currentFilter === 'paid' ? 'active' : '' %>">Paid</a>
                            <a href="/employee/payments?status=pending&date=<%= dateFilter %>" 
                               class="btn btn-outline-warning <%= currentFilter === 'pending' ? 'active' : '' %>">Pending</a>
                            <a href="/employee/payments?status=partial&date=<%= dateFilter %>" 
                               class="btn btn-outline-info <%= currentFilter === 'partial' ? 'active' : '' %>">Partial</a>
                            <a href="/employee/payments?status=overdue&date=<%= dateFilter %>" 
                               class="btn btn-outline-danger <%= currentFilter === 'overdue' ? 'active' : '' %>">Overdue</a>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <h6 class="mb-2">Filter by Date:</h6>
                        <div class="btn-group" role="group">
                            <a href="/employee/payments?status=<%= currentFilter %>&date=today" 
                               class="btn btn-outline-secondary <%= dateFilter === 'today' ? 'active' : '' %>">Today</a>
                            <a href="/employee/payments?status=<%= currentFilter %>&date=week" 
                               class="btn btn-outline-secondary <%= dateFilter === 'week' ? 'active' : '' %>">This Week</a>
                            <a href="/employee/payments?status=<%= currentFilter %>&date=month" 
                               class="btn btn-outline-secondary <%= dateFilter === 'month' ? 'active' : '' %>">This Month</a>
                            <a href="/employee/payments?status=<%= currentFilter %>&date=all" 
                               class="btn btn-outline-secondary <%= dateFilter === 'all' ? 'active' : '' %>">All Time</a>
                        </div>
                    </div>
                    <div class="col-md-4 text-end">
                        <button class="btn btn-success" onclick="exportPayments()">
                            <i class="bi bi-download"></i> Export to CSV
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Payments Table -->
        <div class="card">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="bi bi-cash-stack me-2"></i>
                    Payment Records
                </h5>
                <span class="badge bg-primary"><%= payments.length %> Records</span>
            </div>
            <div class="card-body">
                <% if (payments && payments.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover" id="paymentsTable">
                            <thead class="table-light">
                                <tr>
                                    <th>Receipt No.</th>
                                    <th>Customer</th>
                                    <th>Loan ID</th>
                                    <th>Amount</th>
                                    <th>Method</th>
                                    <th>Status</th>
                                    <th>Date</th>
                                    <th>Posted By</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% payments.forEach(payment => { %>
                                <tr class="payment-card <%= payment.payment_status %>">
                                    <td>
                                        <% if (payment.receipt_number) { %>
                                            <strong class="text-primary"><%= payment.receipt_number %></strong>
                                            <br>
                                            <small class="text-muted">
                                                <i class="bi bi-calendar3"></i> 
                                                <%= payment.posted_at ? new Date(payment.posted_at).toLocaleTimeString() : 'N/A' %>
                                            </small>
                                        <% } else { %>
                                            <span class="text-muted">Not Generated</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <div class="fw-bold"><%= payment.first_name %> <%= payment.last_name %></div>
                                        <small class="text-muted">
                                            <i class="bi bi-card-id"></i> <%= payment.pension_number || 'N/A' %>
                                        </small>
                                        <br>
                                        <small class="text-muted">
                                            <i class="bi bi-phone"></i> <%= payment.mobile_number || 'N/A' %>
                                        </small>
                                    </td>
                                    <td>
                                        <span class="badge bg-dark">#<%= payment.loan_id %></span>
                                        <br>
                                        <small class="text-muted"><%= payment.loan_type || 'Regular' %></small>
                                    </td>
                                    <td>
                                        <strong class="text-success">₱<%= parseFloat(payment.amount_paid).toLocaleString() %></strong>
                                        <% if (payment.amount_due && payment.amount_paid < payment.amount_due) { %>
                                            <br>
                                            <small class="text-warning">
                                                Due: ₱<%= parseFloat(payment.amount_due).toLocaleString() %>
                                            </small>
                                        <% } %>
                                        <% if (payment.amount_due && payment.amount_paid > payment.amount_due) { %>
                                            <br>
                                            <small class="text-info">
                                                Overpayment: ₱<%= (parseFloat(payment.amount_paid) - parseFloat(payment.amount_due)).toLocaleString() %>
                                            </small>
                                        <% } %>
                                    </td>
                                    <td class="text-capitalize">
                                        <span class="badge bg-secondary">
                                            <i class="bi bi-<%= payment.payment_method === 'cash' ? 'cash-stack' : 
                                                           payment.payment_method === 'bank_transfer' ? 'building-bank' :
                                                           payment.payment_method === 'gcash' ? 'phone' : 'credit-card' %>"></i>
                                            <%= payment.payment_method ? payment.payment_method.replace('_', ' ') : 'N/A' %>
                                        </span>
                                        <% if (payment.reference_number) { %>
                                            <br>
                                            <small class="text-muted">Ref: <%= payment.reference_number %></small>
                                        <% } %>
                                    </td>
                                    <td>
                                        <span class="badge bg-<%= 
                                            payment.payment_status === 'paid' ? 'success' : 
                                            payment.payment_status === 'pending' ? 'warning' : 
                                            payment.payment_status === 'partial' ? 'info' : 'danger'
                                        %>">
                                            <i class="bi bi-<%= 
                                                payment.payment_status === 'paid' ? 'check-circle' : 
                                                payment.payment_status === 'pending' ? 'hourglass' : 
                                                payment.payment_status === 'partial' ? 'clock-history' : 'exclamation-circle'
                                            %>"></i>
                                            <%= payment.payment_status ? payment.payment_status.toUpperCase() : 'UNKNOWN' %>
                                        </span>
                                    </td>
                                    <td>
                                        <%= payment.payment_date ? new Date(payment.payment_date).toLocaleDateString('en-US', { 
                                            year: 'numeric', 
                                            month: 'short', 
                                            day: 'numeric' 
                                        }) : 'N/A' %>
                                    </td>
                                    <td>
                                        <div class="fw-bold"><%= payment.posted_by_name || 'System' %></div>
                                        <small class="text-muted">
                                            <i class="bi bi-clock"></i> 
                                            <%= payment.posted_at ? new Date(payment.posted_at).toLocaleDateString() : 'N/A' %>
                                        </small>
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <% if (payment.receipt_number) { %>
                                                <button class="btn btn-outline-primary" 
                                                        onclick="viewReceipt(<%= payment.payment_id %>)" 
                                                        title="View Receipt">
                                                    <i class="bi bi-receipt"></i>
                                                </button>
                                                <button class="btn btn-outline-secondary" 
                                                        onclick="printReceipt(<%= payment.payment_id %>)" 
                                                        title="Print Receipt">
                                                    <i class="bi bi-printer"></i>
                                                </button>
                                            <% } %>
                                            <a href="/employee/post-payment/<%= payment.loan_id %>" 
                                               class="btn btn-outline-success" title="Post New Payment">
                                                <i class="bi bi-plus-circle"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                    
                <% } else { %>
                    <div class="text-center py-5">
                        <i class="bi bi-cash-stack display-1 text-muted"></i>
                        <h4 class="mt-3 text-muted">No Payments Found</h4>
                        <p class="text-muted mb-4">
                            <% if (currentFilter !== 'all') { %>
                                No <strong><%= currentFilter %></strong> payments found in the selected date range.
                            <% } else { %>
                                No payment records found in the system.
                            <% } %>
                        </p>
                        <button class="btn btn-primary btn-lg" onclick="showPostPaymentModal()">
                            <i class="bi bi-plus-circle me-2"></i>Post Your First Payment
                        </button>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Post Payment Modal -->
    <div class="modal fade" id="postPaymentModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-credit-card me-2"></i>Post New Payment
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form id="postPaymentForm" action="/employee/process-payment" method="POST">
                    <div class="modal-body">
                        <!-- Step 1: Select Loan -->
                        <div class="mb-4">
                            <label class="form-label fw-bold">Step 1: Select Loan</label>
                            <div class="input-group">
                                <input type="text" class="form-control" id="loanSearchInputModal" 
                                       placeholder="Enter Loan ID or Customer Name">
                                <button class="btn btn-primary" type="button" onclick="searchLoanModal()">
                                    <i class="bi bi-search"></i> Search
                                </button>
                            </div>
                            <div id="loanSearchResultsModal" class="mt-2" style="display: none;"></div>
                        </div>

                        <!-- Loan Details (hidden until loan selected) -->
                        <div id="selectedLoanInfo" style="display: none;">
                            <div class="alert alert-info mb-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>Selected Loan:</strong> <span id="selectedLoanId"></span><br>
                                        <strong>Customer:</strong> <span id="selectedCustomerName"></span><br>
                                        <strong>Monthly Payment:</strong> <span id="selectedMonthlyPayment"></span>
                                    </div>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="clearSelectedLoan()">
                                        <i class="bi bi-x-circle"></i> Change
                                    </button>
                                </div>
                            </div>

                            <input type="hidden" name="loan_id" id="modal_loan_id">
                            <input type="hidden" name="installment_number" id="modal_installment_number">

                            <!-- Step 2: Select Installment -->
                            <div class="mb-3">
                                <label class="form-label fw-bold">Step 2: Select Installment to Pay</label>
                                <div id="installmentListModal" class="installment-list border rounded" style="max-height: 250px; overflow-y: auto;">
                                    <div class="text-center text-muted p-3">Please select a loan first</div>
                                </div>
                            </div>

                            <!-- Step 3: Payment Details -->
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Payment Date *</label>
                                    <input type="date" class="form-control" name="payment_date" required 
                                           value="<%= new Date().toISOString().split('T')[0] %>">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Amount Paid *</label>
                                    <input type="number" step="0.01" class="form-control" name="amount_paid" id="modal_amount_paid" required>
                                    <small class="text-muted">Enter full or partial payment amount</small>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Payment Method *</label>
                                    <select class="form-select" name="payment_method" required>
                                        <option value="cash">💵 Cash</option>
                                        <option value="bank_transfer">🏦 Bank Transfer</option>
                                        <option value="gcash">📱 GCash</option>
                                        <option value="paymaya">📱 PayMaya</option>
                                        <option value="check">📝 Check</option>
                                    </select>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Reference Number</label>
                                    <input type="text" class="form-control" name="reference_number" 
                                           placeholder="Transaction ID / Check Number">
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Notes (Optional)</label>
                                <textarea class="form-control" name="notes" rows="2" 
                                          placeholder="Additional notes about this payment"></textarea>
                            </div>

                            <div class="alert alert-warning">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                <strong>Note:</strong> Partial payments are allowed. A receipt will be generated automatically after successful payment.
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success" id="submitPaymentBtn" disabled>
                            <i class="bi bi-check-circle"></i> Process Payment
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Receipt Modal -->
    <div class="modal fade" id="receiptModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered receipt-modal">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white no-print">
                    <h5 class="modal-title">
                        <i class="bi bi-receipt"></i> Payment Receipt
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="receiptContent">
                    <!-- Receipt content will be loaded here -->
                </div>
                <div class="modal-footer no-print">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary" onclick="printReceiptContent()">
                        <i class="bi bi-printer"></i> Print Receipt
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Auto-dismiss alerts after 5 seconds
        document.addEventListener('DOMContentLoaded', function() {
            setTimeout(function() {
                const alerts = document.querySelectorAll('.alert');
                alerts.forEach(alert => {
                    const bsAlert = new bootstrap.Alert(alert);
                    bsAlert.close();
                });
            }, 5000);
        });

        // Filter by status
        function filterByStatus(status) {
            window.location.href = `/employee/payments?status=${status}&date=<%= dateFilter %>`;
        }

        // ==================== QUICK SEARCH FUNCTIONS ====================
        
        // Search loan in quick search
        function searchLoan() {
            const searchTerm = document.getElementById('loanSearchInput').value;
            if (!searchTerm) {
                alert('Please enter a Loan ID, Customer Name, or Pension Number');
                return;
            }

            fetch(`/api/search-loan?q=${encodeURIComponent(searchTerm)}`)
                .then(response => response.json())
                .then(data => {
                    const resultsDiv = document.getElementById('loanSearchResults');
                    if (data.success && data.loans && data.loans.length > 0) {
                        let html = '<div class="alert alert-success"><div class="list-group">';
                        data.loans.forEach(loan => {
                            html += `
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <strong>Loan #${loan.loan_id}</strong><br>
                                            ${loan.first_name} ${loan.last_name}<br>
                                            Monthly Payment: ₱${parseFloat(loan.monthly_payment).toLocaleString()}
                                        </div>
                                        <a href="/employee/post-payment/${loan.loan_id}" 
                                           class="btn btn-primary btn-sm">
                                            <i class="bi bi-credit-card"></i> Post Payment
                                        </a>
                                    </div>
                                </div>
                            `;
                        });
                        html += '</div></div>';
                        resultsDiv.innerHTML = html;
                        resultsDiv.style.display = 'block';
                    } else {
                        resultsDiv.innerHTML = `
                            <div class="alert alert-warning">
                                <i class="bi bi-exclamation-triangle"></i>
                                No loan found with "${searchTerm}"
                            </div>
                        `;
                        resultsDiv.style.display = 'block';
                    }
                })
                .catch(error => {
                    console.error('Error searching loan:', error);
                    document.getElementById('loanSearchResults').innerHTML = `
                        <div class="alert alert-danger">
                            Error searching for loan. Please try again.
                        </div>
                    `;
                    document.getElementById('loanSearchResults').style.display = 'block';
                });
        }

        // ==================== MODAL PAYMENT FUNCTIONS ====================
        
        // Show Post Payment Modal
        function showPostPaymentModal() {
            document.getElementById('postPaymentForm').reset();
            document.getElementById('selectedLoanInfo').style.display = 'none';
            document.getElementById('loanSearchInputModal').value = '';
            document.getElementById('loanSearchResultsModal').style.display = 'none';
            document.getElementById('installmentListModal').innerHTML = '<div class="text-center text-muted p-3">Please select a loan first</div>';
            document.getElementById('submitPaymentBtn').disabled = true;
            new bootstrap.Modal(document.getElementById('postPaymentModal')).show();
        }

        // Search loan in modal
        function searchLoanModal() {
            const searchTerm = document.getElementById('loanSearchInputModal').value;
            if (!searchTerm) {
                alert('Please enter a Loan ID or Customer Name');
                return;
            }

            fetch(`/api/search-loan?q=${encodeURIComponent(searchTerm)}`)
                .then(response => response.json())
                .then(data => {
                    const resultsDiv = document.getElementById('loanSearchResultsModal');
                    if (data.success && data.loans && data.loans.length > 0) {
                        let html = '<div class="list-group">';
                        data.loans.forEach(loan => {
                            html += `
                                <div class="list-group-item list-group-item-action" 
                                     onclick="selectLoanForPayment(${loan.loan_id}, '${loan.first_name} ${loan.last_name}', ${loan.monthly_payment})"
                                     style="cursor: pointer;">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <strong>Loan #${loan.loan_id}</strong><br>
                                            ${loan.first_name} ${loan.last_name}<br>
                                            <small>Monthly: ₱${parseFloat(loan.monthly_payment).toLocaleString()}</small>
                                        </div>
                                        <i class="bi bi-chevron-right"></i>
                                    </div>
                                </div>
                            `;
                        });
                        html += '</div>';
                        resultsDiv.innerHTML = html;
                        resultsDiv.style.display = 'block';
                    } else {
                        resultsDiv.innerHTML = `
                            <div class="alert alert-warning">
                                <i class="bi bi-exclamation-triangle"></i>
                                No loan found with "${searchTerm}"
                            </div>
                        `;
                        resultsDiv.style.display = 'block';
                    }
                })
                .catch(error => {
                    console.error('Error searching loan:', error);
                    document.getElementById('loanSearchResultsModal').innerHTML = `
                        <div class="alert alert-danger">
                            Error searching for loan. Please try again.
                        </div>
                    `;
                    document.getElementById('loanSearchResultsModal').style.display = 'block';
                });
        }

        // Select loan for payment
        function selectLoanForPayment(loanId, customerName, monthlyPayment) {
            document.getElementById('modal_loan_id').value = loanId;
            document.getElementById('selectedLoanId').innerHTML = `#${loanId}`;
            document.getElementById('selectedCustomerName').innerHTML = customerName;
            document.getElementById('selectedMonthlyPayment').innerHTML = `₱${parseFloat(monthlyPayment).toLocaleString()}`;
            document.getElementById('modal_amount_paid').value = monthlyPayment;
            document.getElementById('selectedLoanInfo').style.display = 'block';
            document.getElementById('loanSearchResultsModal').style.display = 'none';
            
            // Load installments
            loadInstallmentsModal(loanId);
        }

        // Clear selected loan
        function clearSelectedLoan() {
            document.getElementById('selectedLoanInfo').style.display = 'none';
            document.getElementById('modal_loan_id').value = '';
            document.getElementById('loanSearchInputModal').value = '';
            document.getElementById('submitPaymentBtn').disabled = true;
            document.getElementById('installmentListModal').innerHTML = '<div class="text-center text-muted p-3">Please select a loan first</div>';
        }

        // Load installments for modal
        function loadInstallmentsModal(loanId) {
            fetch(`/api/loan/${loanId}/installments`)
                .then(response => response.json())
                .then(data => {
                    const container = document.getElementById('installmentListModal');
                    if (data.success && data.installments && data.installments.length > 0) {
                        const pendingInstallments = data.installments.filter(inst => inst.status !== 'paid');
                        if (pendingInstallments.length > 0) {
                            container.innerHTML = pendingInstallments.map(inst => `
                                <div class="installment-item p-3 border-bottom" 
                                     onclick="selectInstallmentModal(this, ${inst.installment_number}, ${inst.total_amount})"
                                     style="cursor: pointer; transition: background 0.2s;">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <strong>Installment ${inst.installment_number}</strong>
                                            <br>
                                            <small class="text-muted">Due: ${new Date(inst.due_date).toLocaleDateString()}</small>
                                        </div>
                                        <div class="text-end">
                                            <strong class="text-primary">₱${parseFloat(inst.total_amount).toLocaleString()}</strong>
                                            <br>
                                            <span class="badge bg-${inst.status === 'overdue' ? 'danger' : 'warning'}">
                                                ${inst.status}
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            `).join('');
                            document.getElementById('submitPaymentBtn').disabled = false;
                        } else {
                            container.innerHTML = '<div class="text-center text-success p-3">✓ All installments are paid for this loan!</div>';
                            document.getElementById('submitPaymentBtn').disabled = true;
                        }
                    } else {
                        container.innerHTML = '<div class="text-center text-muted p-3">No installments found for this loan</div>';
                        document.getElementById('submitPaymentBtn').disabled = true;
                    }
                })
                .catch(error => {
                    console.error('Error loading installments:', error);
                    document.getElementById('installmentListModal').innerHTML = '<div class="text-center text-danger p-3">Error loading installments</div>';
                    document.getElementById('submitPaymentBtn').disabled = true;
                });
        }

        // Select installment in modal
        function selectInstallmentModal(element, installmentNumber, amount) {
            // Remove selected class from all
            document.querySelectorAll('#installmentListModal .installment-item').forEach(item => {
                item.classList.remove('selected');
                item.style.background = '';
            });
            // Add selected class to clicked element
            element.classList.add('selected');
            element.style.background = '#e3f2fd';
            // Set values
            document.getElementById('modal_installment_number').value = installmentNumber;
            document.getElementById('modal_amount_paid').value = amount;
        }

        // ==================== RECEIPT FUNCTIONS ====================
        
        // View receipt
        function viewReceipt(paymentId) {
            fetch(`/api/payment-receipt/${paymentId}`)
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        const receipt = data.receipt;
                        document.getElementById('receiptContent').innerHTML = `
                            <div class="text-center mb-4">
                                <h4>Millenium Cash</h4>
                                <p class="mb-0">Official Payment Receipt</p>
                                <small>Receipt #: ${receipt.receipt_number}</small>
                            </div>
                            <div class="row mb-3">
                                <div class="col-6">
                                    <small class="text-muted">Date:</small><br>
                                    <strong>${new Date(receipt.payment_date).toLocaleDateString()}</strong>
                                </div>
                                <div class="col-6 text-end">
                                    <small class="text-muted">Time:</small><br>
                                    <strong>${new Date(receipt.payment_date).toLocaleTimeString()}</strong>
                                </div>
                            </div>
                            <hr>
                            <div class="mb-3">
                                <small class="text-muted">Customer Name:</small><br>
                                <strong>${receipt.first_name} ${receipt.last_name}</strong>
                            </div>
                            <div class="mb-3">
                                <small class="text-muted">Pension Number:</small><br>
                                <strong>${receipt.pension_number || 'N/A'}</strong>
                            </div>
                            <div class="mb-3">
                                <small class="text-muted">Loan ID:</small><br>
                                <strong>#${receipt.loan_id}</strong>
                            </div>
                            <div class="mb-3">
                                <small class="text-muted">Payment Details:</small><br>
                                <table class="table table-sm table-bordered">
                                    <tr>
                                        <td><strong>Amount Paid:</strong></td>
                                        <td class="text-end"><strong>₱${parseFloat(receipt.amount_paid).toLocaleString()}</strong></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Payment Method:</strong></td>
                                        <td class="text-end text-capitalize">${receipt.payment_method}</td>
                                    </tr>
                                    ${receipt.reference_number ? `
                                    <tr>
                                        <td><strong>Reference #:</strong></td>
                                        <td class="text-end">${receipt.reference_number}</td>
                                    </tr>
                                    ` : ''}
                                    <tr>
                                        <td><strong>Status:</strong></td>
                                        <td class="text-end">
                                            <span class="badge bg-success">${receipt.payment_status.toUpperCase()}</span>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                            <hr>
                            <div class="text-center">
                                <small class="text-muted">Processed by: ${receipt.posted_by_name}</small><br>
                                <small class="text-muted">Thank you for your payment!</small>
                            </div>
                        `;
                        new bootstrap.Modal(document.getElementById('receiptModal')).show();
                    } else {
                        alert('Error loading receipt: ' + (data.message || 'Unknown error'));
                    }
                })
                .catch(error => {
                    console.error('Error loading receipt:', error);
                    alert('Error loading receipt. Please try again.');
                });
        }

        // Print receipt
        function printReceipt(paymentId) {
            viewReceipt(paymentId);
            setTimeout(() => {
                printReceiptContent();
            }, 1000);
        }

        function printReceiptContent() {
            const receiptContent = document.getElementById('receiptContent').innerHTML;
            const printWindow = window.open('', '_blank');
            printWindow.document.write(`
                <html>
                    <head>
                        <title>Payment Receipt</title>
                        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
                        <style>
                            body { padding: 20px; }
                            @media print {
                                body { margin: 0; padding: 0; }
                                .no-print { display: none; }
                            }
                        </style>
                    </head>
                    <body>
                        ${receiptContent}
                        <div class="text-center mt-4 no-print">
                            <button onclick="window.print()" class="btn btn-primary">Print</button>
                            <button onclick="window.close()" class="btn btn-secondary">Close</button>
                        </div>
                    </body>
                </html>
            `);
            printWindow.document.close();
        }

        // ==================== UTILITY FUNCTIONS ====================
        
        // Export payments to CSV
        function exportPayments() {
            const status = '<%= currentFilter %>';
            const date = '<%= dateFilter %>';
            window.location.href = `/api/export-payments?status=${status}&date=${date}`;
        }

        // Enter key search for quick search
        const searchInput = document.getElementById('loanSearchInput');
        if (searchInput) {
            searchInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    searchLoan();
                }
            });
        }

        // Enter key search for modal search
        const modalSearchInput = document.getElementById('loanSearchInputModal');
        if (modalSearchInput) {
            modalSearchInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    searchLoanModal();
                }
            });
        }

        // Form submission validation
        document.getElementById('postPaymentForm').addEventListener('submit', function(e) {
            const loanId = document.getElementById('modal_loan_id').value;
            if (!loanId) {
                e.preventDefault();
                alert('Please select a loan first');
                return false;
            }
            const installmentNumber = document.getElementById('modal_installment_number').value;
            if (!installmentNumber) {
                e.preventDefault();
                alert('Please select an installment to pay');
                return false;
            }
            const amountPaid = document.getElementById('modal_amount_paid').value;
            if (!amountPaid || parseFloat(amountPaid) <= 0) {
                e.preventDefault();
                alert('Please enter a valid payment amount');
                return false;
            }
            return true;
        });
    </script>
</body>
</html>